<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="comprehensure.DASHBOARD.ModulesDashboard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F2F6FB"
    Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Background decorative blobs -->
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" InputTransparent="True">
            <Ellipse Fill="White"    WidthRequest="580" HeightRequest="440"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="-140,-110,0,0" Opacity="0.75" />
            <Ellipse Fill="#D6EAFF" WidthRequest="460" HeightRequest="380"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-110,-60" Opacity="0.45" />
        </Grid>

        <ScrollView VerticalOptions="FillAndExpand">
            <VerticalStackLayout Padding="40,36,40,56" Spacing="28">

                <!-- ══════════════════════════════════════ -->
                <!--  HEADER BAR                           -->
                <!-- ══════════════════════════════════════ -->
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">

                    <!-- Back button -->
                    <Border Grid.Column="0"
                            BackgroundColor="White" Stroke="#CBDCEB" StrokeThickness="1"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,4" Radius="12" Opacity="0.07" />
                        </Border.Shadow>
                        <Button Text="← Back"
                                Clicked="BackButton_Clicked"
                                BackgroundColor="Transparent"
                                TextColor="#0F2D4A"
                                BorderWidth="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                HeightRequest="44"
                                Padding="20,0" />
                    </Border>

                    <!-- Title + subtitle -->
                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="2">
                        <Label Text="MODULES"
                               TextColor="#0F2D4A"
                               FontSize="30" FontAttributes="Bold"
                               HorizontalOptions="Center"
                               CharacterSpacing="1.5" />
                        <Label Text="Read each story carefully!"
                               TextColor="#6B8CAE" FontSize="13"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Spacer to balance back button -->
                    <BoxView Grid.Column="2" WidthRequest="90" BackgroundColor="Transparent" />
                </Grid>

                <!-- ══════════════════════════════════════ -->
                <!--  DIFFICULTY LEGEND                    -->
                <!-- ══════════════════════════════════════ -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
                    <Border Padding="14,8" BackgroundColor="#E8F5E9" Stroke="#A5D6A7" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Label Text="🟢  Easy" FontSize="12" FontAttributes="Bold" TextColor="#2E7D32" />
                    </Border>
                    <Border Padding="14,8" BackgroundColor="#FFF8E1" Stroke="#FFD54F" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Label Text="🟡  Average" FontSize="12" FontAttributes="Bold" TextColor="#F57F17" />
                    </Border>
                    <Border Padding="14,8" BackgroundColor="#FBE9E7" Stroke="#FFAB91" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Label Text="🔴  Intermediate" FontSize="12" FontAttributes="Bold" TextColor="#BF360C" />
                    </Border>
                </HorizontalStackLayout>

                <!-- ══════════════════════════════════════ -->
                <!--  MODULE CARDS GRID                    -->
                <!-- ══════════════════════════════════════ -->
                <FlexLayout
                    AlignContent="Start"
                    AlignItems="Start"
                    Direction="Row"
                    JustifyContent="Center"
                    Wrap="Wrap">

                    <!-- ── MODULE 1 – Easy ── -->
                    <Border Margin="12" WidthRequest="300" BackgroundColor="White"
                            Stroke="#CBDCEB" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, *, Auto" Padding="24,24,24,28" RowSpacing="14">

                            <!-- Thumbnail -->
                            <Border Grid.Row="0" HeightRequest="130"
                                    BackgroundColor="#EBF4FF" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22"/>
                                </Border.StrokeShape>
                                <Image Source="module_icon1.png" Aspect="AspectFit" Margin="16"/>
                            </Border>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Row="1" Spacing="6" VerticalOptions="Center">
                                <Border Padding="10,5" BackgroundColor="#E8F5E9"
                                        Stroke="#A5D6A7" StrokeThickness="1"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🟢  Easy" FontSize="11" FontAttributes="Bold"
                                           TextColor="#2E7D32" />
                                </Border>
                                <Label Text="The Forgotten Library"
                                       FontAttributes="Bold" FontSize="18"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#0F2D4A"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <!-- CTA -->
                            <Border Grid.Row="2" BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                </Border.Shadow>
                                <Button Text="START READING"
                                        Command="{Binding startmodule1Command}"
                                        BackgroundColor="Transparent" TextColor="White"
                                        BorderWidth="0" HeightRequest="52"
                                        FontAttributes="Bold" FontSize="13"
                                        CharacterSpacing="1.0" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── MODULE 2 – Easy ── -->
                    <Border Margin="12" WidthRequest="300" BackgroundColor="White"
                            Stroke="#CBDCEB" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, *, Auto" Padding="24,24,24,28" RowSpacing="14">
                            <Border Grid.Row="0" HeightRequest="130"
                                    BackgroundColor="#EBF4FF" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22"/>
                                </Border.StrokeShape>
                                <Image Source="module_icon2.png" Aspect="AspectFit" Margin="16"/>
                            </Border>
                            <VerticalStackLayout Grid.Row="1" Spacing="6" VerticalOptions="Center">
                                <Border Padding="10,5" BackgroundColor="#E8F5E9"
                                        Stroke="#A5D6A7" StrokeThickness="1"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🟢  Easy" FontSize="11" FontAttributes="Bold" TextColor="#2E7D32" />
                                </Border>
                                <Label Text="The Clockmaker's Secret"
                                       FontAttributes="Bold" FontSize="18"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#0F2D4A" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <Border Grid.Row="2" BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                </Border.Shadow>
                                <Button Text="START READING"
                                        Command="{Binding startmodule2Command}"
                                        BackgroundColor="Transparent" TextColor="White"
                                        BorderWidth="0" HeightRequest="52"
                                        FontAttributes="Bold" FontSize="13"
                                        CharacterSpacing="1.0" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── MODULE 3 – Easy ── -->
                    <Border Margin="12" WidthRequest="300" BackgroundColor="White"
                            Stroke="#CBDCEB" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, *, Auto" Padding="24,24,24,28" RowSpacing="14">
                            <Border Grid.Row="0" HeightRequest="130"
                                    BackgroundColor="#EBF4FF" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22"/>
                                </Border.StrokeShape>
                                <Image Source="module_icon3.png" Aspect="AspectFit" Margin="16"/>
                            </Border>
                            <VerticalStackLayout Grid.Row="1" Spacing="6" VerticalOptions="Center">
                                <Border Padding="10,5" BackgroundColor="#E8F5E9"
                                        Stroke="#A5D6A7" StrokeThickness="1"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🟢  Easy" FontSize="11" FontAttributes="Bold" TextColor="#2E7D32" />
                                </Border>
                                <Label Text="The Observatory on the Hill"
                                       FontAttributes="Bold" FontSize="18"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#0F2D4A" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <Border Grid.Row="2" BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                </Border.Shadow>
                                <Button Text="START READING"
                                        Command="{Binding startmodule3Command}"
                                        BackgroundColor="Transparent" TextColor="White"
                                        BorderWidth="0" HeightRequest="52"
                                        FontAttributes="Bold" FontSize="13"
                                        CharacterSpacing="1.0" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── MODULE 4 – Average ── -->
                    <Border Margin="12" WidthRequest="300" BackgroundColor="White"
                            Stroke="#CBDCEB" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, *, Auto" Padding="24,24,24,28" RowSpacing="14">
                            <Border Grid.Row="0" HeightRequest="130"
                                    BackgroundColor="#FFF8E1" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22"/>
                                </Border.StrokeShape>
                                <Image Source="module_icon4.png" Aspect="AspectFit" Margin="16"/>
                            </Border>
                            <VerticalStackLayout Grid.Row="1" Spacing="6" VerticalOptions="Center">
                                <Border Padding="10,5" BackgroundColor="#FFF8E1"
                                        Stroke="#FFD54F" StrokeThickness="1"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🟡  Average" FontSize="11" FontAttributes="Bold" TextColor="#F57F17" />
                                </Border>
                                <Label Text="The Garden of Hidden Patterns"
                                       FontAttributes="Bold" FontSize="18"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#0F2D4A" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <Border Grid.Row="2" BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                </Border.Shadow>
                                <Button Text="START READING"
                                        Command="{Binding startmodule4Command}"
                                        BackgroundColor="Transparent" TextColor="White"
                                        BorderWidth="0" HeightRequest="52"
                                        FontAttributes="Bold" FontSize="13"
                                        CharacterSpacing="1.0" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── MODULE 5 – Average ── -->
                    <Border Margin="12" WidthRequest="300" BackgroundColor="White"
                            Stroke="#CBDCEB" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, *, Auto" Padding="24,24,24,28" RowSpacing="14">
                            <Border Grid.Row="0" HeightRequest="130"
                                    BackgroundColor="#FFF8E1" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22"/>
                                </Border.StrokeShape>
                                <Image Source="module_icon5.png" Aspect="AspectFit" Margin="16"/>
                            </Border>
                            <VerticalStackLayout Grid.Row="1" Spacing="6" VerticalOptions="Center">
                                <Border Padding="10,5" BackgroundColor="#FFF8E1"
                                        Stroke="#FFD54F" StrokeThickness="1"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🟡  Average" FontSize="11" FontAttributes="Bold" TextColor="#F57F17" />
                                </Border>
                                <Label Text="The Map of Quiet Decisions"
                                       FontAttributes="Bold" FontSize="18"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#0F2D4A" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <Border Grid.Row="2" BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                </Border.Shadow>
                                <Button Text="START READING"
                                        Command="{Binding startmodule5Command}"
                                        BackgroundColor="Transparent" TextColor="White"
                                        BorderWidth="0" HeightRequest="52"
                                        FontAttributes="Bold" FontSize="13"
                                        CharacterSpacing="1.0" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── MODULE 6 – Average ── -->
                    <Border Margin="12" WidthRequest="300" BackgroundColor="White"
                            Stroke="#CBDCEB" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, *, Auto" Padding="24,24,24,28" RowSpacing="14">
                            <Border Grid.Row="0" HeightRequest="130"
                                    BackgroundColor="#FFF8E1" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22"/>
                                </Border.StrokeShape>
                                <Image Source="module_icon6.png" Aspect="AspectFit" Margin="16"/>
                            </Border>
                            <VerticalStackLayout Grid.Row="1" Spacing="6" VerticalOptions="Center">
                                <Border Padding="10,5" BackgroundColor="#FFF8E1"
                                        Stroke="#FFD54F" StrokeThickness="1"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🟡  Average" FontSize="11" FontAttributes="Bold" TextColor="#F57F17" />
                                </Border>
                                <Label Text="The Weight of Paper Wings"
                                       FontAttributes="Bold" FontSize="18"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#0F2D4A" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <Border Grid.Row="2" BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                </Border.Shadow>
                                <Button Text="START READING"
                                        Command="{Binding startmodule6Command}"
                                        BackgroundColor="Transparent" TextColor="White"
                                        BorderWidth="0" HeightRequest="52"
                                        FontAttributes="Bold" FontSize="13"
                                        CharacterSpacing="1.0" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── MODULE 7 – Intermediate ── -->
                    <Border Margin="12" WidthRequest="300" BackgroundColor="White"
                            Stroke="#CBDCEB" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, *, Auto" Padding="24,24,24,28" RowSpacing="14">
                            <Border Grid.Row="0" HeightRequest="130"
                                    BackgroundColor="#FBE9E7" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22"/>
                                </Border.StrokeShape>
                                <Image Source="module_icon7.png" Aspect="AspectFit" Margin="16"/>
                            </Border>
                            <VerticalStackLayout Grid.Row="1" Spacing="6" VerticalOptions="Center">
                                <Border Padding="10,5" BackgroundColor="#FBE9E7"
                                        Stroke="#FFAB91" StrokeThickness="1"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🔴  Intermediate" FontSize="11" FontAttributes="Bold" TextColor="#BF360C" />
                                </Border>
                                <Label Text="The City of Silent Bargains"
                                       FontAttributes="Bold" FontSize="18"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#0F2D4A" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <Border Grid.Row="2" BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                </Border.Shadow>
                                <Button Text="START READING"
                                        Command="{Binding startmodule7Command}"
                                        BackgroundColor="Transparent" TextColor="White"
                                        BorderWidth="0" HeightRequest="52"
                                        FontAttributes="Bold" FontSize="13"
                                        CharacterSpacing="1.0" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── MODULE 8 – Intermediate ── -->
                    <Border Margin="12" WidthRequest="300" BackgroundColor="White"
                            Stroke="#CBDCEB" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                        </Border.Shadow>
                        <Grid RowDefinitions="Auto, *, Auto" Padding="24,24,24,28" RowSpacing="14">
                            <Border Grid.Row="0" HeightRequest="130"
                                    BackgroundColor="#FBE9E7" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22"/>
                                </Border.StrokeShape>
                                <Image Source="module_icon8.png" Aspect="AspectFit" Margin="16"/>
                            </Border>
                            <VerticalStackLayout Grid.Row="1" Spacing="6" VerticalOptions="Center">
                                <Border Padding="10,5" BackgroundColor="#FBE9E7"
                                        Stroke="#FFAB91" StrokeThickness="1"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="🔴  Intermediate" FontSize="11" FontAttributes="Bold" TextColor="#BF360C" />
                                </Border>
                                <Label Text="Whispers of the Iron Forest"
                                       FontAttributes="Bold" FontSize="18"
                                       HorizontalTextAlignment="Center"
                                       TextColor="#0F2D4A" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <Border Grid.Row="2" BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                </Border.Shadow>
