<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="comprehensure.DASHBOARD.ModulesDashboard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F4F8FB"
    Shell.NavBarIsVisible="False">

    <ScrollView VerticalOptions="FillAndExpand">
        <VerticalStackLayout Padding="30" Spacing="20">

            <Grid ColumnDefinitions="Auto, *">
                <Button Grid.Column="0"
                        Text="← Back" 
                        Clicked="BackButton_Clicked"
                        BackgroundColor="Transparent"
                        TextColor="#507D9B"
                        FontAttributes="Bold"
                        FontSize="16" />

                <Label Grid.Column="1"
                       Text="LEARNING MODULES"
                       TextColor="#1B3A57"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,0,80,0" />
            </Grid>

            <FlexLayout
                AlignContent="Start"
                AlignItems="Start"
                Direction="Row"
                JustifyContent="Center"
                Wrap="Wrap">

                <Border x:Name="M1" Margin="15" BackgroundColor="White" HeightRequest="400" StrokeThickness="0" WidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow x:Name="S1" Brush="#80c2ed" Opacity="0.15" Radius="15" Offset="0,8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
                        <Border Grid.Row="0" HeightRequest="120" BackgroundColor="#F0F8FF" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Image Source="module_icon1.png" Aspect="AspectFit" Margin="10"/>
                        </Border>
                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="18" HorizontalTextAlignment="Center" Text="Module 1" TextColor="#1B3A57" />
                            <Label FontSize="13" HorizontalTextAlignment="Center" Text="Introduction" TextColor="#507D9B" />
                        </VerticalStackLayout>
                        <Button Grid.Row="2" BackgroundColor="#80c2ed" CornerRadius="15" FontAttributes="Bold" HeightRequest="50" Text="START" TextColor="White" Command="{Binding startmodule1Command}"/>
                    </Grid>
                </Border>

                <Border x:Name="M2" Margin="15" BackgroundColor="White" HeightRequest="400" StrokeThickness="0" WidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow x:Name="S2" Brush="#80c2ed" Opacity="0.15" Radius="15" Offset="0,8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
                        <Border Grid.Row="0" HeightRequest="120" BackgroundColor="#F0F8FF" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Image Source="module_icon2.png" Aspect="AspectFit" Margin="10"/>
                        </Border>
                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="18" HorizontalTextAlignment="Center" Text="Module 2" TextColor="#1B3A57" />
                            <Label FontSize="13" HorizontalTextAlignment="Center" Text="Vocabulary" TextColor="#507D9B" />
                        </VerticalStackLayout>
                        <Button Grid.Row="2" BackgroundColor="#80c2ed" CornerRadius="15" FontAttributes="Bold" HeightRequest="50" Text="START" TextColor="White" Command="{Binding startmodule2Command}"/>
                    </Grid>
                </Border>

                <Border x:Name="M3" Margin="15" BackgroundColor="White" HeightRequest="400" StrokeThickness="0" WidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow x:Name="S3" Brush="#80c2ed" Opacity="0.15" Radius="15" Offset="0,8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
                        <Border Grid.Row="0" HeightRequest="120" BackgroundColor="#F0F8FF" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Image Source="module_icon3.png" Aspect="AspectFit" Margin="10"/>
                        </Border>
                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="18" HorizontalTextAlignment="Center" Text="Module 3" TextColor="#1B3A57" />
                            <Label FontSize="13" HorizontalTextAlignment="Center" Text="Context Clues" TextColor="#507D9B" />
                        </VerticalStackLayout>
                        <Button Grid.Row="2" BackgroundColor="#80c2ed" CornerRadius="15" FontAttributes="Bold" HeightRequest="50" Text="START" TextColor="White" Command="{Binding startmodule3Command}"/>
                    </Grid>
                </Border>

                <Border x:Name="M4" Margin="15" BackgroundColor="White" HeightRequest="400" StrokeThickness="0" WidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow x:Name="S4" Brush="#80c2ed" Opacity="0.15" Radius="15" Offset="0,8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
                        <Border Grid.Row="0" HeightRequest="120" BackgroundColor="#F0F8FF" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Image Source="module_icon4.png" Aspect="AspectFit" Margin="10"/>
                        </Border>
                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="18" HorizontalTextAlignment="Center" Text="Module 4" TextColor="#1B3A57" />
                            <Label FontSize="13" HorizontalTextAlignment="Center" Text="Main Ideas" TextColor="#507D9B" />
                        </VerticalStackLayout>
                        <Button Grid.Row="2" BackgroundColor="#80c2ed" CornerRadius="15" FontAttributes="Bold" HeightRequest="50" Text="START" TextColor="White" Command="{Binding startmodule4Command}"/>
                    </Grid>
                </Border>

                <Border x:Name="M5" Margin="15" BackgroundColor="White" HeightRequest="400" StrokeThickness="0" WidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow x:Name="S5" Brush="#80c2ed" Opacity="0.15" Radius="15" Offset="0,8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
                        <Border Grid.Row="0" HeightRequest="120" BackgroundColor="#F0F8FF" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Image Source="module_icon5.png" Aspect="AspectFit" Margin="10"/>
                        </Border>
                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="18" HorizontalTextAlignment="Center" Text="Module 5" TextColor="#1B3A57" />
                            <Label FontSize="13" HorizontalTextAlignment="Center" Text="Inference" TextColor="#507D9B" />
                        </VerticalStackLayout>
                        <Button Grid.Row="2" BackgroundColor="#80c2ed" CornerRadius="15" FontAttributes="Bold" HeightRequest="50" Text="START" TextColor="White" Command="{Binding startmodule5Command}"/>
                    </Grid>
                </Border>

                <Border x:Name="M6" Margin="15" BackgroundColor="White" HeightRequest="400" StrokeThickness="0" WidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow x:Name="S6" Brush="#80c2ed" Opacity="0.15" Radius="15" Offset="0,8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
                        <Border Grid.Row="0" HeightRequest="120" BackgroundColor="#F0F8FF" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Image Source="module_icon6.png" Aspect="AspectFit" Margin="10"/>
                        </Border>
                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="18" HorizontalTextAlignment="Center" Text="Module 6" TextColor="#1B3A57" />
                            <Label FontSize="13" HorizontalTextAlignment="Center" Text="Summarizing" TextColor="#507D9B" />
                        </VerticalStackLayout>
                        <Button Grid.Row="2" BackgroundColor="#80c2ed" CornerRadius="15" FontAttributes="Bold" HeightRequest="50" Text="START" TextColor="White" Command="{Binding startmodule6Command}"/>
                    </Grid>
                </Border>

                <Border x:Name="M7" Margin="15" BackgroundColor="White" HeightRequest="400" StrokeThickness="0" WidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow x:Name="S7" Brush="#80c2ed" Opacity="0.15" Radius="15" Offset="0,8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
                        <Border Grid.Row="0" HeightRequest="120" BackgroundColor="#F0F8FF" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Image Source="module_icon7.png" Aspect="AspectFit" Margin="10"/>
                        </Border>
                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="18" HorizontalTextAlignment="Center" Text="Module 7" TextColor="#1B3A57" />
                            <Label FontSize="13" HorizontalTextAlignment="Center" Text="Critical Analysis" TextColor="#507D9B" />
                        </VerticalStackLayout>
                        <Button Grid.Row="2" BackgroundColor="#80c2ed" CornerRadius="15" FontAttributes="Bold" HeightRequest="50" Text="START" TextColor="White" Command="{Binding startmodule7Command}"/>
                    </Grid>
                </Border>

                <Border x:Name="M8" Margin="15" BackgroundColor="White" HeightRequest="400" StrokeThickness="0" WidthRequest="220">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow x:Name="S8" Brush="#80c2ed" Opacity="0.15" Radius="15" Offset="0,8" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
                        <Border Grid.Row="0" HeightRequest="120" BackgroundColor="#F0F8FF" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Image Source="module_icon8.png" Aspect="AspectFit" Margin="10"/>
                        </Border>
                        <VerticalStackLayout Grid.Row="1" Spacing="5" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="18" HorizontalTextAlignment="Center" Text="Module 8" TextColor="#1B3A57" />
                            <Label FontSize="13" HorizontalTextAlignment="Center" Text="Mastery Test" TextColor="#507D9B" />
                        </VerticalStackLayout>
                        <Button Grid.Row="2" BackgroundColor="#80c2ed" CornerRadius="15" FontAttributes="Bold" HeightRequest="50" Text="START" TextColor="White" Command="{Binding startmodule8Command}"/>
                    </Grid>
                </Border>

            </FlexLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>