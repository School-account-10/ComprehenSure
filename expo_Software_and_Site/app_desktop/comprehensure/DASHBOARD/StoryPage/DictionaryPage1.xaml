                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" Padding="20,18,20,18">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <Label Grid.Column="0" Text="Dusty" FontSize="20" FontAttributes="Bold" TextColor="#E8F0FF"/>
