                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <Label Grid.Column="0" Text="Narrow" FontSize="20" FontAttributes="Bold" TextColor="#E8F0FF"/>
                                    <Border Grid.Column="1" BackgroundColor="#0F1A30" Stroke="#1E3A6B" StrokeThickness="1" Padding="10,4">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Label Text="/ˈna-row/" FontSize="11" TextColor="#4A90D9" FontAttributes="Italic"/>
                                    </Border>
                                
                                    <Button Grid.Column="2"
                                            Text="🔊"
                                            FontSize="18"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Padding="8,0"
                                            HeightRequest="36"
                                            WidthRequest="44"
                                            Clicked="OnSpeakClicked"
                                            CommandParameter="Narrow"/>
                                </Grid>
                                <Label Text="Something that is not wide." FontSize="14" TextColor="#7EB8F7" LineHeight="1.5"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- UNUSUAL -->
                    <Border BackgroundColor="#0D1528" Stroke="#8B6914" StrokeThickness="1" Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,8" Radius="24" Opacity="0.4"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="8,*" ColumnSpacing="0">
                            <Border Grid.Column="0" Stroke="Transparent" StrokeThickness="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#2E6BA8" Offset="0"/>
                                        <GradientStop Color="#1A3F6B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20,0,0,20"/>
                                </Border.StrokeShape>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" Padding="20,18,20,18">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <Label Grid.Column="0" Text="Unusual" FontSize="20" FontAttributes="Bold" TextColor="#E8F0FF"/>
                                    <Border Grid.Column="1" BackgroundColor="#0F1A30" Stroke="#1E3A6B" StrokeThickness="1" Padding="10,4">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Label Text="/'un-yush-wəl/" FontSize="11" TextColor="#4A90D9" FontAttributes="Italic"/>
                                    </Border>
                                
                                    <Button Grid.Column="2"
                                            Text="🔊"
                                            FontSize="18"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Padding="8,0"
