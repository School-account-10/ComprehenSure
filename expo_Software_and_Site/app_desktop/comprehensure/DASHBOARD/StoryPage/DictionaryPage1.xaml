                                    <Border Grid.Column="1" BackgroundColor="#0F1A30" Stroke="#1E3A6B" StrokeThickness="1" Padding="10,4">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Label Text="/ˈpa-se-g/" FontSize="11" TextColor="#4A90D9" FontAttributes="Italic"/>
                                    </Border>
                                
                                    <Button Grid.Column="2"
                                            Text="🔊"
                                            FontSize="18"
                                            BackgroundColor="Transparent"
