                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Label Text="/ˈdus-ti/" FontSize="11" TextColor="#4A90D9" FontAttributes="Italic"/>
                                    </Border>
                                
                                    <Button Grid.Column="2"
                                            Text="🔊"
                                            FontSize="18"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Padding="8,0"
                                            HeightRequest="36"
                                            WidthRequest="44"
                                            Clicked="OnSpeakClicked"
                                            CommandParameter="Dusty"/>
                                </Grid>
                                <Label Text="Covered with fine dry particles." FontSize="14" TextColor="#7EB8F7" LineHeight="1.5"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- CURIOUS -->
                    <Border BackgroundColor="#0D1528" Stroke="#8B6914" StrokeThickness="1" Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,8" Radius="24" Opacity="0.4"/>
