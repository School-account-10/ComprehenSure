                                </Grid>
                                <Label Text="Eager to learn or know something." FontSize="14" TextColor="#7EB8F7" LineHeight="1.5"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- NARROW -->
                    <Border BackgroundColor="#0D1528" Stroke="#8B6914" StrokeThickness="1" Padding="0">
