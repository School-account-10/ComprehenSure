                <!--  HERO HEADER                        -->
                <!-- ═══════════════════════════════════ -->
                <Grid Padding="32,52,32,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Back button -->
                    <Border Grid.Row="0"
                            BackgroundColor="#0F1A30" Stroke="#1E3A6B" StrokeThickness="1"
                            HorizontalOptions="Start" Margin="0,0,0,28">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Button Text="← Back to Story"
                                x:Name="BackBtn"
                                Clicked="OnBackClicked"
                                BackgroundColor="Transparent"
                                TextColor="#7EB8F7"
                                BorderWidth="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                HeightRequest="44"
                                Padding="20,0"/>
                    </Border>

                    <!-- Book icon row -->
                    <HorizontalStackLayout Grid.Row="1" Spacing="14"
                                           HorizontalOptions="Center"
                                           Margin="0,0,0,16">
                        <!-- Decorative lines -->
                        <BoxView BackgroundColor="#1E3A6B" HeightRequest="1" WidthRequest="60"
                                 VerticalOptions="Center"/>
                        <Label Text="📖" FontSize="36" VerticalOptions="Center"/>
                        <BoxView BackgroundColor="#1E3A6B" HeightRequest="1" WidthRequest="60"
                                 VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Title block -->
                    <VerticalStackLayout Grid.Row="2" Spacing="6" HorizontalOptions="Center">
                        <Label Text="VOCABULARY"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="#4A90D9" CharacterSpacing="5"
                               HorizontalOptions="Center"/>
                        <Label Text="The City of Silent Bargains"
                               FontSize="28" FontAttributes="Bold"
                               TextColor="#E8F0FF"
                               HorizontalOptions="Center"/>
                        <Label Text="17 words to know"
                               FontSize="13" TextColor="#4A6A9A"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>

