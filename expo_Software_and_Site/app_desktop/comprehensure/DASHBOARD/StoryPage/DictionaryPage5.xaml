                                        <GradientStop Color="#1A3F6B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20,0,0,20"/>
                                </Border.StrokeShape>
                            </Border>
