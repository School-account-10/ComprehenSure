<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.StoryPage.StoryPage1"
             BackgroundColor="#F4F8FB"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto">

        <Border Grid.Row="0" BackgroundColor="#80c2ed" StrokeThickness="0" HeightRequest="100">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,30,30" />
            </Border.StrokeShape>
            <Label Text="The Forgotten Library" FontSize="22" FontAttributes="Bold" 
                   TextColor="#1B3A57" HorizontalOptions="Center" VerticalOptions="Center" />
        </Border>

        <Grid Grid.Row="1">
            <Border x:Name="MainStoryCard"
                    BackgroundColor="White" 
                    Padding="40" 
                    StrokeThickness="0" 
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    MaximumWidthRequest="600"
                    Margin="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1B3A57" Opacity="0.1" Offset="0,15" Radius="20" />
                </Border.Shadow>

                <ScrollView x:Name="StoryScroll">
                    <Label x:Name="StoryLabel" 
                           FontSize="20" 
                           TextColor="#1B3A57" 
                           LineHeight="1.6" 
                           HorizontalTextAlignment="Center" 
                           VerticalTextAlignment="Center"
                           FontFamily="Calibri" />
                </ScrollView>
            </Border>

            <Grid ColumnDefinitions="*, *" HorizontalOptions="Fill" VerticalOptions="Fill">
                <Button Grid.Column="0" Text="◀" Clicked="OnPrevClicked" 
                        HorizontalOptions="Start" VerticalOptions="Center"
                        BackgroundColor="#CCFFFFFF" TextColor="#1B3A57" CornerRadius="30"
                        HeightRequest="60" WidthRequest="60" FontSize="25" Margin="10" 
                        ZIndex="1" />

                <Button Grid.Column="1" Text="▶" Clicked="OnNextClicked" 
                        HorizontalOptions="End" VerticalOptions="Center"
                        BackgroundColor="#CCFFFFFF" TextColor="#1B3A57" CornerRadius="30"
                        HeightRequest="60" WidthRequest="60" FontSize="25" Margin="10" 
                        ZIndex="1" />
            </Grid>
        </Grid>

        <VerticalStackLayout Grid.Row="2" Spacing="10" Padding="0,0,0,30">
            <Label x:Name="PageIndicator" Text="Page 1 of 11" HorizontalOptions="Center" 
                   TextColor="#507D9B" FontAttributes="Italic" />

            <Button Text="GO TO QUIZ" Clicked="OnGoToQuizClicked"
                    BackgroundColor="#1B3A57" TextColor="White" FontAttributes="Bold"
                    CornerRadius="30" HeightRequest="55" WidthRequest="220" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>