<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.StoryPage.QuizPage7"
             BackgroundColor="#F2F6FB"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- ── Background decorative blobs (mirrors StoryPage1) ── -->
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" InputTransparent="True">
            <Ellipse Fill="White"   WidthRequest="580" HeightRequest="440"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="-140,-110,0,0" Opacity="0.75" />
            <Ellipse Fill="#D6EAFF" WidthRequest="460" HeightRequest="380"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-110,-60" Opacity="0.45" />
        </Grid>

        <ScrollView>
            <VerticalStackLayout Spacing="24" Padding="40,36,40,56"
                                 HorizontalOptions="Center"
                                 MaximumWidthRequest="720">

                <!-- ══════════════════════════════════════ -->
                <!--  TOP BAR — back + module badge        -->
                <!-- ══════════════════════════════════════ -->
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">

                    <!-- Back button -->
                    <Border Grid.Column="0"
                            BackgroundColor="White" Stroke="#CBDCEB" StrokeThickness="1"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,4" Radius="12" Opacity="0.07" />
                        </Border.Shadow>
                        <Button Text="← Back"
                                Clicked="OnBackClicked"
                                BackgroundColor="Transparent"
                                TextColor="#0F2D4A"
                                BorderWidth="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                HeightRequest="44"
                                Padding="20,0" />
                    </Border>

                    <!-- Centre title -->
                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="2">
                        <Label Text="MODULE 7"
                               FontSize="10" FontAttributes="Bold"
                               TextColor="#2E6BA8" CharacterSpacing="2.2"
                               HorizontalOptions="Center" />
                        <Label Text="Comprehension Quiz"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="#0F2D4A"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Difficulty badge -->
                    <Border Grid.Column="2"
                            Padding="14,8" BackgroundColor="#E8F5E9"
                            Stroke="#A5D6A7" StrokeThickness="1"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Label Text="Easy" FontSize="12"
                               FontAttributes="Bold" TextColor="#2E7D32" />
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════ -->
                <!--  PROGRESS BAR                         -->
                <!-- ══════════════════════════════════════ -->
                <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               x:Name="QuestionNumberLabel"
                               Text="{Binding QuestionNumber}"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="#6B8CAE" />
                        <Label Grid.Column="1"
                               x:Name="ProgressPercent"
                               Text="0%"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="#2E6BA8" />
                    </Grid>

                    <!-- Track -->
                    <Border BackgroundColor="#E2EAF4"
                            Stroke="Transparent" StrokeThickness="0"
                            HeightRequest="8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="4" />
                        </Border.StrokeShape>
                        <!-- Fill — WidthRequest set from code-behind -->
                        <Border x:Name="ProgressFill"
                                BackgroundColor="#0F2D4A"
                                Stroke="Transparent" StrokeThickness="0"
                                HeightRequest="8"
                                HorizontalOptions="Start"
                                WidthRequest="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4" />
                            </Border.StrokeShape>
                        </Border>
                    </Border>
                </VerticalStackLayout>

                <!-- ══════════════════════════════════════ -->
                <!--  QUESTION CARD                        -->
                <!-- ══════════════════════════════════════ -->
                <Border BackgroundColor="White"
                        Stroke="#CBDCEB" StrokeThickness="1"
                        Padding="44,40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="36" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,10" Radius="32" Opacity="0.07" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="8">
                        <!-- Decorative open-quote -->
                        <Label Text="&#x201C;"
                               FontSize="72" TextColor="#2E6BA8"
                               Opacity="0.18"
                               Margin="0,-20,0,-28"
                               HorizontalOptions="Start" />

                        <Label x:Name="QuestionText"
                               Text="{Binding Mainquestion}"
                               FontSize="17"
                               TextColor="#1A2E42"
                               LineHeight="1.85"
                               HorizontalTextAlignment="Start"
                               VerticalOptions="Start" />

                        <!-- Decorative close-quote -->
                        <Label Text="&#x201D;"
                               FontSize="72" TextColor="#2E6BA8"
                               Opacity="0.18"
                               Margin="0,-28,0,-16"
                               HorizontalOptions="End" />
                    </VerticalStackLayout>
                </Border>

                <!-- ══════════════════════════════════════ -->
                <!--  ANSWER OPTIONS                       -->
                <!-- ══════════════════════════════════════ -->
                <VerticalStackLayout x:Name="OptionsContainer" Spacing="14">

                    <!-- Option A -->
                    <Border x:Name="BorderA"
                            BackgroundColor="White" Stroke="#CBDCEB" StrokeThickness="1"
                            Padding="20,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,4" Radius="12" Opacity="0.05" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="34,*" ColumnSpacing="16">
                            <!-- Letter badge -->
                            <Border Grid.Column="0" x:Name="CircleA"
                                    HeightRequest="34" WidthRequest="34"
                                    BackgroundColor="Transparent"
                                    Stroke="#CBDCEB" StrokeThickness="1.5"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="17" />
                                </Border.StrokeShape>
                                <Label Text="A" FontSize="13" FontAttributes="Bold"
                                       TextColor="#2E6BA8"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" x:Name="BtnA" Text="{Binding Ch1bt}"
                                   VerticalOptions="Center"
                                   FontSize="15" TextColor="#1A2E42"
                                   LineBreakMode="WordWrap" />
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionClicked" CommandParameter="A" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Option B -->
                    <Border x:Name="BorderB"
                            BackgroundColor="White" Stroke="#CBDCEB" StrokeThickness="1"
                            Padding="20,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,4" Radius="12" Opacity="0.05" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="34,*" ColumnSpacing="16">
                            <Border Grid.Column="0" x:Name="CircleB"
                                    HeightRequest="34" WidthRequest="34"
                                    BackgroundColor="Transparent"
                                    Stroke="#CBDCEB" StrokeThickness="1.5"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="17" />
                                </Border.StrokeShape>
                                <Label Text="B" FontSize="13" FontAttributes="Bold"
                                       TextColor="#2E6BA8"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" x:Name="BtnB" Text="{Binding Ch2bt}"
                                   VerticalOptions="Center"
                                   FontSize="15" TextColor="#1A2E42"
                                   LineBreakMode="WordWrap" />
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionClicked" CommandParameter="B" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Option C -->
                    <Border x:Name="BorderC"
                            BackgroundColor="White" Stroke="#CBDCEB" StrokeThickness="1"
                            Padding="20,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,4" Radius="12" Opacity="0.05" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="34,*" ColumnSpacing="16">
                            <Border Grid.Column="0" x:Name="CircleC"
                                    HeightRequest="34" WidthRequest="34"
                                    BackgroundColor="Transparent"
                                    Stroke="#CBDCEB" StrokeThickness="1.5"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="17" />
                                </Border.StrokeShape>
                                <Label Text="C" FontSize="13" FontAttributes="Bold"
                                       TextColor="#2E6BA8"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" x:Name="BtnC" Text="{Binding Ch3bt}"
                                   VerticalOptions="Center"
                                   FontSize="15" TextColor="#1A2E42"
                                   LineBreakMode="WordWrap" />
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionClicked" CommandParameter="C" />
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Option D -->
                    <Border x:Name="BorderD"
                            BackgroundColor="White" Stroke="#CBDCEB" StrokeThickness="1"
                            Padding="20,16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,4" Radius="12" Opacity="0.05" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="34,*" ColumnSpacing="16">
                            <Border Grid.Column="0" x:Name="CircleD"
                                    HeightRequest="34" WidthRequest="34"
                                    BackgroundColor="Transparent"
                                    Stroke="#CBDCEB" StrokeThickness="1.5"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="17" />
                                </Border.StrokeShape>
                                <Label Text="D" FontSize="13" FontAttributes="Bold"
                                       TextColor="#2E6BA8"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Label Grid.Column="1" x:Name="BtnD" Text="{Binding Ch4bt}"
                                   VerticalOptions="Center"
                                   FontSize="15" TextColor="#1A2E42"
                                   LineBreakMode="WordWrap" />
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOptionClicked" CommandParameter="D" />
                        </Border.GestureRecognizers>
                    </Border>

                </VerticalStackLayout>

                <!-- ══════════════════════════════════════ -->
                <!--  NAVIGATION ROW                       -->
                <!-- ══════════════════════════════════════ -->
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="16">


                    <!-- Next button -->
                    <Border Grid.Column="1"
                            BackgroundColor="#0F2D4A"
                            Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,6" Radius="16" Opacity="0.22" />
                        </Border.Shadow>
                        <Button x:Name="NextButton"
                                Text="Next  ▶"
                                Clicked="OnNextClicked"
                                IsEnabled="False"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                BorderWidth="0"
                                FontAttributes="Bold" FontSize="13"
                                HeightRequest="52" Padding="22,0" />
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════ -->
                <!--  QUIZ COMPLETE BANNER (hidden)        -->
                <!-- ══════════════════════════════════════ -->
                <Border x:Name="CompleteBanner"
                        IsVisible="False"
                        Stroke="#E8C547" StrokeThickness="1.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFF8DC" Offset="0" />
                            <GradientStop Color="#FAF0CA" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*, Auto" Padding="28,20" ColumnSpacing="16">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                            <Label Text="Quiz Complete!"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#0F2D4A" />
                            <Label x:Name="FinalScoreLabel"
                                   Text="You scored 0 out of 0"
                                   FontSize="13" TextColor="#6B8CAE" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                BackgroundColor="#0F2D4A"
                                Stroke="Transparent" StrokeThickness="0"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                            </Border.Shadow>
                            <Button Text="FINISH  →"
                                    Clicked="OnFinishClicked"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    BorderWidth="0"
                                    FontAttributes="Bold" FontSize="13"
                                    CharacterSpacing="0.8"
                                    HeightRequest="48" Padding="22,0" />
                        </Border>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════ -->
        <!--  BACK CONFIRMATION POPUP                      -->
        <!-- ══════════════════════════════════════════════ -->
        <Grid x:Name="PopupOverlay"
              IsVisible="False"
              BackgroundColor="#80000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">

            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="400"
                    BackgroundColor="White"
                    Stroke="#CBDCEB"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="36" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#0F2D4A" Offset="0,16" Radius="48" Opacity="0.18" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">

                    <!-- Top gradient accent band -->
                    <Border HeightRequest="6" Stroke="Transparent" StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0F2D4A" Offset="0" />
                                <GradientStop Color="#2E6BA8" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36,36,0,0" />
                        </Border.StrokeShape>
                    </Border>

                    <VerticalStackLayout Spacing="20" Padding="36,28,36,32">

                        <!-- Title -->
                        <Label Text="Leave Quiz?"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#0F2D4A"
                               HorizontalOptions="Center" />

                        <!-- Body -->
                        <Label Text="Your quiz progress won't be saved. Are you sure you want to go back?"
                               FontSize="14" TextColor="#6B8CAE"
                               HorizontalTextAlignment="Center"
                               LineHeight="1.6"
                               LineBreakMode="WordWrap" />

                        <!-- Divider -->
                        <BoxView HeightRequest="1" BackgroundColor="#EBF4FF" Margin="0,4" />

                        <!-- Buttons -->
                        <VerticalStackLayout Spacing="12">

                            <Border BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,6" Radius="16" Opacity="0.22" />
                                </Border.Shadow>
                                <Button Text="Yes, leave quiz"
                                        Clicked="OnPopupConfirm"
                                        BackgroundColor="Transparent"
                                        TextColor="White"
                                        BorderWidth="0"
                                        FontAttributes="Bold" FontSize="14"
                                        HeightRequest="52" />
                            </Border>

                            <Border BackgroundColor="Transparent"
                                    Stroke="#CBDCEB" StrokeThickness="1.5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26" />
                                </Border.StrokeShape>
                                <Button Text="Keep answering"
                                        Clicked="OnPopupCancel"
                                        BackgroundColor="Transparent"
                                        TextColor="#0F2D4A"
                                        BorderWidth="0"
                                        FontAttributes="Bold" FontSize="14"
                                        HeightRequest="52" />
                            </Border>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
