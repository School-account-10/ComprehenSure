                <!--  HERO HEADER                        -->
                <!-- ═══════════════════════════════════ -->
                <Grid Padding="32,52,32,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

