<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.StoryPage.StoryPage5" 
             BackgroundColor="#F2F6FB"
             Shell.NavBarIsVisible="False">



    <Grid>

        <!-- Blurred thumbnail background -->
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" InputTransparent="True">
            <!-- Full-screen thumbnail image -->
            <Image Source="t5.png"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill"
                   Opacity="0.95" />
            <!-- Frosted glass overlay -->
            <BoxView BackgroundColor="#6B8CAE" Opacity="0.30"
                     HorizontalOptions="Fill" VerticalOptions="Fill" />
        </Grid>

        <ScrollView>



            <VerticalStackLayout Spacing="24" Padding="40,36,40,56"
                                 HorizontalOptions="Center"
                                 MaximumWidthRequest="720">

                <!-- ══════════════════════════════════════ -->
                <!--  TOP BAR — back + module badge        -->
                <!-- ══════════════════════════════════════ -->
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">


                    
                    <!-- Back button -->
                    <Border Grid.Column="0"
           BackgroundColor="White" Stroke="#CBDCEB" StrokeThickness="1"
           VerticalOptions="Center"
           x:Name="PrevBtnBorder">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,4" Radius="12" Opacity="0.08" />
                        </Border.Shadow>
                        <Button Text="← Back"
               x:Name="PrevBtn"
               Clicked="OnBackClicked"
               BackgroundColor="Transparent"
               TextColor="#0F2D4A"
               BorderWidth="0"
               FontAttributes="Bold"
               FontSize="13"
               HeightRequest="44"
               Padding="20,0" />
                    </Border>

                    <!-- Module label -->
                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="2">
                        <Label Text="MODULE 5"
                               FontSize="10" FontAttributes="Bold"
                               TextColor="#0F2D4A" CharacterSpacing="2.2"
                               HorizontalOptions="Center" />
                        <Label Text="The Map of Quiet Decisions"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="#0F2D4A"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Difficulty badge -->
                    <Border Grid.Column="2"
                            Padding="14,8" BackgroundColor="#E8F5E9"
                            Stroke="#A5D6A7" StrokeThickness="1"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Label Text="🟡  Average" FontSize="12"
                               FontAttributes="Bold" TextColor="#F57F17" />
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════ -->
                <!--  PROGRESS BAR                         -->
                <!-- ══════════════════════════════════════ -->
                <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0"
                               x:Name="PageIndicator"
                               Text="Page 1 of 7"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="#0F2D4A" />
                        <Label Grid.Column="1"
                               x:Name="ProgressPercent"
                               Text="14%"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="#0F2D4A" />
                    </Grid>

                    <!-- Track -->
                    <Border BackgroundColor="#D6EAFF" Opacity="0.8"
                            Stroke="Transparent" StrokeThickness="0"
                            HeightRequest="8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="4" />
                        </Border.StrokeShape>
                        <Border x:Name="ProgressFill"
                                BackgroundColor="#0F2D4A"
                                Stroke="Transparent" StrokeThickness="0"
                                HeightRequest="8"
                                HorizontalOptions="Start"
                                WidthRequest="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4" />
                            </Border.StrokeShape>
                        </Border>
                    </Border>
                </VerticalStackLayout>

                <!-- ══════════════════════════════════════ -->
                <!--  STORY CARD                           -->
                <!-- ══════════════════════════════════════ -->
                <Border BackgroundColor="White"
                        Stroke="#CBDCEB" StrokeThickness="1"
                        Padding="44,40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="36" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,10" Radius="32" Opacity="0.10" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <!-- Decorative open-quote -->
                        <Label Text="&#x201C;"
                               FontSize="72" TextColor="#0F2D4A"
                               Opacity="0.30"
                               Margin="0,-20,0,-28"
                               HorizontalOptions="Start" />

                        <!-- Story text -->
                        <Label x:Name="StoryLabel"
                               FontSize="17"
                               TextColor="#0F2D4A"
                               LineHeight="1.85"
                               HorizontalTextAlignment="Start"
                               VerticalOptions="Start" />

                        <!-- Decorative close-quote -->
                        <Label Text="&#x201D;"
                               FontSize="72" TextColor="#0F2D4A"
                               Opacity="0.30"
                               Margin="0,-28,0,-16"
                               HorizontalOptions="End" />

                    </VerticalStackLayout>
                </Border>

                <!-- ══════════════════════════════════════ -->
                <!--  NAVIGATION BAR — dots + next         -->
                <!-- ══════════════════════════════════════ -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">

                    <!-- Page dots -->
                    <HorizontalStackLayout Grid.Column="1"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Spacing="8">
                        <BoxView x:Name="Dot1" WidthRequest="10" HeightRequest="10"
                                 CornerRadius="5" BackgroundColor="#0F2D4A" />
                        <BoxView x:Name="Dot2" WidthRequest="8" HeightRequest="8"
                                 CornerRadius="4" BackgroundColor="#CBDCEB" Opacity="0.5" />
                        <BoxView x:Name="Dot3" WidthRequest="8" HeightRequest="8"
                                 CornerRadius="4" BackgroundColor="#CBDCEB" Opacity="0.5" />
                        <BoxView x:Name="Dot4" WidthRequest="8" HeightRequest="8"
                                 CornerRadius="4" BackgroundColor="#CBDCEB" Opacity="0.5" />
                        <BoxView x:Name="Dot5" WidthRequest="8" HeightRequest="8"
                                 CornerRadius="4" BackgroundColor="#CBDCEB" Opacity="0.5" />
                        <BoxView x:Name="Dot6" WidthRequest="8" HeightRequest="8"
                                 CornerRadius="4" BackgroundColor="#CBDCEB" Opacity="0.5" />
                        <BoxView x:Name="Dot7" WidthRequest="8" HeightRequest="8"
                                 CornerRadius="4" BackgroundColor="#CBDCEB" Opacity="0.5" />
                        <BoxView x:Name="Dot8" WidthRequest="8" HeightRequest="8"
                                 CornerRadius="4" BackgroundColor="#CBDCEB" Opacity="0.5" />
                        <BoxView x:Name="Dot9" WidthRequest="8" HeightRequest="8"
                                 CornerRadius="4" BackgroundColor="#CBDCEB" Opacity="0.5" />
                    </HorizontalStackLayout>

                    <!-- Next -->
                    <Border Grid.Column="2"
                            BackgroundColor="#0F2D4A" Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,6" Radius="16" Opacity="0.22" />
                        </Border.Shadow>
                        <Button x:Name="NextBtn"
                                Text="Next  ▶"
                                Clicked="OnNextClicked"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                BorderWidth="0"
                                FontAttributes="Bold" FontSize="13"
                                HeightRequest="52" Padding="22,0" />
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════ -->
                <!--  DICTIONARY BUTTON                    -->
                <!-- ══════════════════════════════════════ -->
                <Border BackgroundColor="#D6EAFF"
                        Stroke="#CBDCEB" StrokeThickness="1" Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,6" Radius="18" Opacity="0.12"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="24,16" ColumnSpacing="14">
                        <!-- Book icon chip -->
                        <Border Grid.Column="0"
                                BackgroundColor="White"
                                Stroke="#CBDCEB" StrokeThickness="1"
                                HeightRequest="44" WidthRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22"/>
                            </Border.StrokeShape>
                            <Label Text="📖" FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <!-- Text -->
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="VOCABULARY GUIDE"
                                   FontSize="10" FontAttributes="Bold"
                                   TextColor="#0F2D4A" CharacterSpacing="2"/>
                            <Label Text="View all words &amp; pronunciations"
                                   FontSize="13" TextColor="#6B8CAE"/>
                        </VerticalStackLayout>
                        <!-- Arrow chip -->
                        <Border Grid.Column="2"
                                BackgroundColor="#0F2D4A"
                                Stroke="Transparent" StrokeThickness="0"
                                HeightRequest="36" WidthRequest="36"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18"/>
                            </Border.StrokeShape>
                            <Label Text="→" FontSize="16" FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <!-- Tap gesture over the whole row -->
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDictionaryClicked"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════ -->
                <!--  GO TO QUIZ — only shows on last page -->
                <!-- ══════════════════════════════════════ -->
                <Border x:Name="QuizBanner"
                        IsVisible="False"
                        Stroke="#CBDCEB" StrokeThickness="1.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#D6EAFF" Offset="0" />
                            <GradientStop Color="#E8F0F8" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*, Auto" Padding="28,20" ColumnSpacing="16">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                            <Label Text="🎉 Story Complete!"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#0F2D4A" />
                            <Label Text="Test your comprehension now."
                                   FontSize="13" TextColor="#6B8CAE" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                BackgroundColor="#0F2D4A"
                                Stroke="Transparent" StrokeThickness="0"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                            </Border.Shadow>
                            <Button Text="GO TO QUIZ  →"
                                    Clicked="OnGoToQuizClicked"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    BorderWidth="0"
                                    FontAttributes="Bold" FontSize="13"
                                    CharacterSpacing="0.8"
                                    HeightRequest="48" Padding="22,0" />
                        </Border>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- CUSTOM BACK CONFIRMATION POPUP -->
        <Grid x:Name="PopupOverlay"
              IsVisible="False"
              BackgroundColor="#60000000"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">

            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="400"
                    BackgroundColor="White"
                    Stroke="#CBDCEB"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="36" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#0F2D4A" Offset="0,16" Radius="48" Opacity="0.15" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="0">

                    <!-- Top gradient accent band -->
                    <Border HeightRequest="6" Stroke="Transparent" StrokeThickness="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0F2D4A" Offset="0" />
                                <GradientStop Color="#4A7FA8" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="36,36,0,0" />
                        </Border.StrokeShape>
                    </Border>

                    <VerticalStackLayout Spacing="20" Padding="36,28,36,32">

                        <!-- Icon chip -->
                        <Border BackgroundColor="#D6EAFF"
                                Stroke="Transparent" StrokeThickness="0"
                                HeightRequest="64" WidthRequest="64"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="32" />
                            </Border.StrokeShape>
                            <Label Text="&#x1F4D6;"
                                   FontSize="30"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Title -->
                        <Label Text="Leave Story?"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#0F2D4A"
                               HorizontalOptions="Center" />

                        <!-- Body message -->
                        <Label Text="Your progress on this page won't be saved. Are you sure you want to go back to the modules?"
                               FontSize="14" TextColor="#6B8CAE"
                               HorizontalTextAlignment="Center"
                               LineHeight="1.6"
                               LineBreakMode="WordWrap" />

                        <!-- Divider -->
                        <BoxView HeightRequest="1" BackgroundColor="#D6EAFF" Margin="0,4" />

                        <!-- Action buttons -->
                        <VerticalStackLayout Spacing="12">

                            <Border BackgroundColor="#0F2D4A"
                                    Stroke="Transparent" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,6" Radius="16" Opacity="0.22" />
                                </Border.Shadow>
                                <Button Text="Yes, leave story"
                                        Clicked="OnPopupConfirm"
                                        BackgroundColor="Transparent"
                                        TextColor="White"
                                        BorderWidth="0"
                                        FontAttributes="Bold" FontSize="14"
                                        HeightRequest="52" />
                            </Border>

                            <Border BackgroundColor="Transparent"
                                    Stroke="#CBDCEB" StrokeThickness="1.5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26" />
                                </Border.StrokeShape>
                                <Button Text="Keep reading"
                                        Clicked="OnPopupCancel"
                                        BackgroundColor="Transparent"
                                        TextColor="#0F2D4A"
                                        BorderWidth="0"
                                        FontAttributes="Bold" FontSize="14"
                                        HeightRequest="52" />
                            </Border>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
