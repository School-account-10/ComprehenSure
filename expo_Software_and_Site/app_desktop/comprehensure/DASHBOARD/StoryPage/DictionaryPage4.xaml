                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Button Text="← Back to Story"
                                x:Name="BackBtn"
                                Clicked="OnBackClicked"
                                BackgroundColor="Transparent"
                                TextColor="#7EB8F7"
                                BorderWidth="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                HeightRequest="44"
                                Padding="20,0"/>
