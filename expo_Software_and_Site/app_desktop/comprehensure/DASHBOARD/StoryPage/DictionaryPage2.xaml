<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.StoryPage.DictionaryPage2"
             BackgroundColor="#0A0F1E"
             Shell.NavBarIsVisible="False">


    <Grid>

        <!-- Background texture blobs -->
        <Grid InputTransparent="True" HorizontalOptions="Fill" VerticalOptions="Fill">
            <Ellipse Fill="#1A2744" WidthRequest="500" HeightRequest="500"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="-180,-180,0,0" Opacity="0.6"/>
            <Ellipse Fill="#0F1A30" WidthRequest="400" HeightRequest="400"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-120,-120" Opacity="0.5"/>
            <Ellipse Fill="#1E2F52" WidthRequest="300" HeightRequest="300"
                     HorizontalOptions="Center" VerticalOptions="Center"
                     Opacity="0.3"/>
        </Grid>

        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="0,0,0,60"
                                 HorizontalOptions="Center"
                                 MaximumWidthRequest="760">

                <!-- ═══════════════════════════════════ -->
                <!--  HERO HEADER                        -->
                <!-- ═══════════════════════════════════ -->
                <Grid Padding="32,52,32,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Back button -->
                    <Border Grid.Row="0"
                            BackgroundColor="#0F1A30" Stroke="#1E3A6B" StrokeThickness="1"
                            HorizontalOptions="Start" Margin="0,0,0,28">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Button Text="← Back to Story"
                                x:Name="BackBtn"
                                Clicked="OnBackClicked"
                                BackgroundColor="Transparent"
                                TextColor="#7EB8F7"
                                BorderWidth="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                HeightRequest="44"
                                Padding="20,0"/>
                    </Border>

                    <!-- Book icon row -->
                    <HorizontalStackLayout Grid.Row="1" Spacing="14"
                                           HorizontalOptions="Center"
                                           Margin="0,0,0,16">
                        <!-- Decorative lines -->
                        <BoxView BackgroundColor="#1E3A6B" HeightRequest="1" WidthRequest="60"
                                 VerticalOptions="Center"/>
                        <Label Text="📖" FontSize="36" VerticalOptions="Center"/>
                        <BoxView BackgroundColor="#1E3A6B" HeightRequest="1" WidthRequest="60"
                                 VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Title block -->
                    <VerticalStackLayout Grid.Row="2" Spacing="6" HorizontalOptions="Center">
                        <Label Text="VOCABULARY"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="#4A90D9" CharacterSpacing="5"
                               HorizontalOptions="Center"/>
                        <Label Text="The Clockmaker's Secret"
                               FontSize="28" FontAttributes="Bold"
                               TextColor="#E8F0FF"
                               HorizontalOptions="Center"/>
                        <Label Text="17 words to know"
                               FontSize="13" TextColor="#4A6A9A"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Divider -->
                <Border HeightRequest="1" Stroke="Transparent" Margin="32,0,32,32">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#1E3A6B" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- ═══════════════════════════════════ -->
                <!--  WORD CARDS                         -->
                <!-- ═══════════════════════════════════ -->
                <VerticalStackLayout Spacing="16" Padding="24,0">

                    <!-- Narrow -->
                    <Border BackgroundColor="#0D1528" Stroke="#8B6914" StrokeThickness="1" Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,8" Radius="24" Opacity="0.4"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="8,*" ColumnSpacing="0">
                            <!-- Left accent strip -->
                            <Border Grid.Column="0" Stroke="Transparent" StrokeThickness="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#2E6BA8" Offset="0"/>
                                        <GradientStop Color="#1A3F6B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20,0,0,20"/>
                                </Border.StrokeShape>
                            </Border>
                            <!-- Content -->
                            <VerticalStackLayout Grid.Column="1" Spacing="6" Padding="20,18,20,18">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <Label Grid.Column="0" Text="Narrow" FontSize="20" FontAttributes="Bold" TextColor="#E8F0FF"/>
                                    <Border Grid.Column="1" BackgroundColor="#0F1A30" Stroke="#1E3A6B" StrokeThickness="1" Padding="10,4">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Label Text="/ˈna-row/" FontSize="11" TextColor="#4A90D9" FontAttributes="Italic"/>
                                    </Border>
                                
                                    <Button Grid.Column="2"
                                            Text="🔊"
                                            FontSize="18"
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            Padding="8,0"
                                            HeightRequest="36"
                                            WidthRequest="44"
                                            Clicked="OnSpeakClicked"
                                            CommandParameter="Narrow"/>
                                </Grid>
                                <Label Text="Narrow describes something not wide." FontSize="14" TextColor="#7EB8F7" LineHeight="1.5"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Cozy -->
