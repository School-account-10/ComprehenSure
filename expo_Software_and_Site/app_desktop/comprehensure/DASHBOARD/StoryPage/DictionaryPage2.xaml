                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Label Text="/ˈko-zi/" FontSize="11" TextColor="#4A90D9" FontAttributes="Italic"/>
                                    </Border>
                                
                                    <Button Grid.Column="2"
