                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,8" Radius="24" Opacity="0.4"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="8,*" ColumnSpacing="0">
                            <Border Grid.Column="0" Stroke="Transparent" StrokeThickness="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#2E6BA8" Offset="0"/>
                                        <GradientStop Color="#1A3F6B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20,0,0,20"/>
                                </Border.StrokeShape>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="6" Padding="20,18,20,18">
