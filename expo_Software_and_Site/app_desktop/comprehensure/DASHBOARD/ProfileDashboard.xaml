<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.ProfileDashboard"
             Title="ProfileDashboard">
    <VerticalStackLayout>
        <Label Text="ComprehenSure" Padding="20,10" TextColor="#1B3A57" FontAttributes="Bold" FontSize="18" />
        <Button
     BackgroundColor="Transparent"
     BorderColor="#80c2ed"
    Command="{Binding logoutCommand}"
     BorderWidth="1"
     CornerRadius="15"
     Text="Logout"
     TextColor="#80c2ed" />
    </VerticalStackLayout>
</ContentPage>