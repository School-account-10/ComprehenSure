<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.UsernameReq"
             BackgroundColor="#F2F6FB"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Background decorative blobs -->
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" InputTransparent="True">
            <Ellipse Fill="White"   WidthRequest="580" HeightRequest="440"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="-140,-110,0,0" Opacity="0.75" />
            <Ellipse Fill="#D6EAFF" WidthRequest="460" HeightRequest="380"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-110,-60" Opacity="0.45" />
        </Grid>

        <ScrollView HorizontalOptions="Center" VerticalOptions="Center">
            <VerticalStackLayout Spacing="28" WidthRequest="440" Padding="20">

                <!-- ── Brand mark ── -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Border BackgroundColor="#0F2D4A"
                            Stroke="Transparent" StrokeThickness="0"
                            HeightRequest="64" WidthRequest="64"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,6" Radius="18" Opacity="0.22" />
                        </Border.Shadow>
                        <Label Text="📖" FontSize="28"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="comprehensure"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#0F2D4A" CharacterSpacing="2.5"
                           HorizontalOptions="Center"
                           Margin="0,6,0,0" />
                </VerticalStackLayout>

                <!-- ── App logo / avatar ── -->
                <Border HeightRequest="110" WidthRequest="110"
                        Stroke="#CBDCEB" StrokeThickness="2"
                        BackgroundColor="#EBF4FF"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="55" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,6" Radius="20" Opacity="0.10" />
                    </Border.Shadow>
                    <Image Source="applogo.jpg"
                           HeightRequest="110" WidthRequest="110"
                           Aspect="AspectFill">
                        <Image.Clip>
                            <EllipseGeometry Center="55,55" RadiusX="55" RadiusY="55" />
                        </Image.Clip>
                    </Image>
                </Border>

                <!-- ── Heading ── -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="Choose Your Username"
                           FontSize="28" FontAttributes="Bold"
                           TextColor="#0F2D4A"
                           HorizontalOptions="Center" />
                    <Label Text="This is how you'll appear to others in the app."
                           TextColor="#6B8CAE" FontSize="14"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- ── Input card ── -->
                <Border BackgroundColor="White"
                        Padding="36,32"
                        Stroke="#CBDCEB" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="36" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,10" Radius="32" Opacity="0.07" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">

                        <!-- Username field -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="USERNAME"
                                   FontSize="10" FontAttributes="Bold"
                                   TextColor="#6B8CAE" CharacterSpacing="1.8" />
                            <Border BackgroundColor="#F2F6FB"
                                    Stroke="#CBDCEB" StrokeThickness="1"
                                    Padding="18,0" HeightRequest="52">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Entry x:Name="UsernameEntry"
                                       Placeholder="e.g. readingpro42"
                                       PlaceholderColor="#A8C4D8"
                                       Text="{Binding Username}"
                                       TextColor="#0F2D4A"
                                       BackgroundColor="Transparent"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       Keyboard="Text"
                                       ReturnType="Done" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Tip banner -->
                        <Border BackgroundColor="#FFF8DC"
                                Stroke="#E8C547" StrokeThickness="1"
                                Padding="16,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="💡" FontSize="14" VerticalOptions="Center" />
                                <Label Text="Pick a name that's easy to remember!"
                                       FontSize="12" TextColor="#5a4200"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" BackgroundColor="#EBF4FF" Margin="0,4" />

                        <!-- Continue button -->
                        <Border BackgroundColor="#0F2D4A"
                                Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="26" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,8" Radius="22" Opacity="0.24" />
                            </Border.Shadow>
                            <Button Text="CONTINUE  →"
                                    Command="{Binding UsernameCheckCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    BorderWidth="0"
                                    HeightRequest="54"
                                    FontAttributes="Bold" FontSize="15"
                                    CharacterSpacing="1.6" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
