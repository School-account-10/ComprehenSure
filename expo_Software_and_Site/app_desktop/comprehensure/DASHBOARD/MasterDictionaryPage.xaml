<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.MasterDictionaryPage"
             BackgroundColor="#0A0F1E"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Background blobs -->
        <Grid InputTransparent="True" HorizontalOptions="Fill" VerticalOptions="Fill">
            <Ellipse Fill="#1A2744" WidthRequest="500" HeightRequest="500"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="-180,-180,0,0" Opacity="0.6"/>
            <Ellipse Fill="#0F1A30" WidthRequest="400" HeightRequest="400"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-120,-120" Opacity="0.5"/>
            <Ellipse Fill="#1E2F52" WidthRequest="300" HeightRequest="300"
                     HorizontalOptions="Center" VerticalOptions="Center"
                     Opacity="0.3"/>
        </Grid>

        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="0,0,0,60"
                                 HorizontalOptions="Center"
                                 MaximumWidthRequest="760">

                <!-- ═══════════════════════════════════ -->
                <!--  HERO HEADER                        -->
                <!-- ═══════════════════════════════════ -->
                <Grid Padding="32,52,32,32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Back button -->
                    <Border Grid.Row="0"
                            BackgroundColor="#0F1A30" Stroke="#1E3A6B" StrokeThickness="1"
                            HorizontalOptions="Start" Margin="0,0,0,28">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Button Text="← Back"
                                Clicked="OnBackClicked"
                                BackgroundColor="Transparent"
                                TextColor="#7EB8F7"
                                BorderWidth="0"
                                FontAttributes="Bold"
                                FontSize="13"
                                HeightRequest="44"
                                Padding="20,0"/>
                    </Border>

                    <!-- Book icon row -->
                    <HorizontalStackLayout Grid.Row="1" Spacing="14"
                                           HorizontalOptions="Center"
                                           Margin="0,0,0,16">
                        <BoxView BackgroundColor="#1E3A6B" HeightRequest="1" WidthRequest="60"
                                 VerticalOptions="Center"/>
                        <Label Text="📚" FontSize="36" VerticalOptions="Center"/>
                        <BoxView BackgroundColor="#1E3A6B" HeightRequest="1" WidthRequest="60"
                                 VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Title block -->
                    <VerticalStackLayout Grid.Row="2" Spacing="6" HorizontalOptions="Center">
                        <Label Text="MASTER VOCABULARY"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="#4A90D9" CharacterSpacing="5"
                               HorizontalOptions="Center"/>
                        <Label Text="All Modules Dictionary"
                               FontSize="28" FontAttributes="Bold"
                               TextColor="#E8F0FF"
                               HorizontalOptions="Center"/>
                        <Label Text="79 words across 8 modules"
                               FontSize="13" TextColor="#4A6A9A"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Divider -->
                <Border HeightRequest="1" Stroke="Transparent" Margin="32,0,32,28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#1E3A6B" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- ═══════════════════════════════════ -->
                <!--  DIFFICULTY FILTER TABS             -->
                <!-- ═══════════════════════════════════ -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12" Padding="24,0,24,24">

                    <!-- EASY tab -->
                    <Border x:Name="EasyTabBorder"
                            Grid.Column="0"
                            BackgroundColor="#1B4A1B"
                            Stroke="#2E7D32" StrokeThickness="1.5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#2E7D32" Offset="0,4" Radius="12" Opacity="0.25"/>
                        </Border.Shadow>
                        <Button x:Name="EasyTab"
                                Text="🟢  EASY&#10;28 words"
                                Clicked="OnEasyTabClicked"
                                BackgroundColor="Transparent"
                                TextColor="#A5D6A7"
                                BorderWidth="0"
                                FontAttributes="Bold"
                                FontSize="12"
                                HeightRequest="60"/>
                    </Border>

                    <!-- AVERAGE tab -->
                    <Border x:Name="AvgTabBorder"
                            Grid.Column="1"
                            BackgroundColor="#0F1A30"
                            Stroke="#1E3A6B" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Button x:Name="AvgTab"
                                Text="🟡  AVERAGE&#10;29 words"
                                Clicked="OnAvgTabClicked"
                                BackgroundColor="Transparent"
                                TextColor="#4A6A9A"
                                BorderWidth="0"
                                FontAttributes="Bold"
                                FontSize="12"
                                HeightRequest="60"/>
                    </Border>

                    <!-- INTERMEDIATE tab -->
                    <Border x:Name="IntTabBorder"
                            Grid.Column="2"
                            BackgroundColor="#0F1A30"
                            Stroke="#1E3A6B" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Button x:Name="IntTab"
                                Text="🔴  INTERMEDIATE&#10;22 words"
                                Clicked="OnIntTabClicked"
                                BackgroundColor="Transparent"
                                TextColor="#4A6A9A"
                                BorderWidth="0"
                                FontAttributes="Bold"
                                FontSize="12"
                                HeightRequest="60"/>
                    </Border>

                </Grid>

