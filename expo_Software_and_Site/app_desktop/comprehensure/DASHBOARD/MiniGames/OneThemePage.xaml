<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.MiniGames.OneThemePage"
             BackgroundColor="#F4F8FB"
             Title="One Theme, One Word">

    <Grid RowDefinitions="Auto, *, Auto" Padding="25">
        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,0,0,20">
            <Label Text="What is the common theme?" 
                   TextColor="#1B3A57" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>

            <VerticalStackLayout Padding="30" Spacing="25">
                <Grid ColumnDefinitions="*,*" RowDefinitions="130,130" ColumnSpacing="15" RowSpacing="15">
                    <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#FEFDE8" Stroke="#eaed80" StrokeThickness="2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Label Text="CLUE 1" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#1B3A57"/>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#FEFDE8" Stroke="#eaed80" StrokeThickness="2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Label Text="CLUE 2" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#1B3A57"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#FEFDE8" Stroke="#eaed80" StrokeThickness="2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Label Text="CLUE 3" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#1B3A57"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#FEFDE8" Stroke="#eaed80" StrokeThickness="2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Label Text="CLUE 4" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#1B3A57"/>
                    </Border>
                </Grid>

                <Entry Placeholder="Type the common word..." HorizontalTextAlignment="Center"
                       TextColor="#1B3A57" FontSize="20" BackgroundColor="#F4F8FB" />
            </VerticalStackLayout>
        </Border>

        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="20" Margin="0,20,0,0">
            <Button Text="SUBMIT" BackgroundColor="#eaed80" TextColor="#1B3A57" FontAttributes="Bold"
                    WidthRequest="160" HeightRequest="55" CornerRadius="28" />
            <Button Text="EXIT" BackgroundColor="Transparent" TextColor="#1B3A57" BorderColor="#1B3A57"
                    BorderWidth="1" WidthRequest="100" HeightRequest="55" CornerRadius="28" Clicked="OnExitClicked" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>