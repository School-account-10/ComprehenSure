<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.MiniGames.OneThemePage"
             BackgroundColor="#0B1D3A"
             Title="4 Pics 1 Theme">

    <!-- ═══════════════════════════════════════════ -->
    <!--  Background cloud ellipses                   -->
    <!-- ═══════════════════════════════════════════ -->
    <Grid>
        <Grid HorizontalOptions="Fill" InputTransparent="True" VerticalOptions="Fill">
            <Ellipse Margin="-100,-60,0,0" Fill="White" HeightRequest="240"
                     HorizontalOptions="Start" Opacity="0.06" VerticalOptions="Start" WidthRequest="360"/>
            <Ellipse Margin="80,-100,0,0" Fill="White" HeightRequest="160"
                     HorizontalOptions="Start" Opacity="0.04" VerticalOptions="Start" WidthRequest="220"/>
            <Ellipse Margin="0,-50,-80,0" Fill="White" HeightRequest="220"
                     HorizontalOptions="End" Opacity="0.06" VerticalOptions="Start" WidthRequest="320"/>
            <Ellipse Margin="0,0,-100,-60" Fill="White" HeightRequest="260"
                     HorizontalOptions="End" Opacity="0.05" VerticalOptions="End" WidthRequest="380"/>
            <Ellipse Margin="-80,0,0,-80" Fill="White" HeightRequest="200"
                     HorizontalOptions="Start" Opacity="0.04" VerticalOptions="End" WidthRequest="300"/>
            <Ellipse Margin="0,-180,0,0" Fill="#3B82F6" HeightRequest="300"
                     HorizontalOptions="Center" Opacity="0.08" VerticalOptions="Start" WidthRequest="500"/>
        </Grid>

        <!-- ═══════════════════════════════════════════ -->
        <!--  Main content                               -->
        <!-- ═══════════════════════════════════════════ -->
        <ScrollView>
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Padding="28,24,28,40" RowSpacing="0">

                <!-- ── TOP BAR: title + score + module info ── -->
                <Border Grid.Row="0"
                        Padding="20,16" Margin="0,0,0,18"
                        Stroke="Transparent" StrokeThickness="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#FFFFFF"/>
                            <GradientStop Offset="1" Color="#EEF4FF"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Opacity="0.18" Radius="24" Offset="0,6"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <!-- Exit -->
                        <Button Grid.Column="0"
                                Text="← EXIT"
                                BackgroundColor="Transparent"
                                TextColor="#1565C0"
                                FontAttributes="Bold"
                                FontSize="13"
                                BorderColor="#DBEAFE"
                                BorderWidth="1.5"
                                CornerRadius="18"
                                HeightRequest="40"
                                WidthRequest="90"
                                Clicked="OnExitClicked"/>

                        <!-- Title + module -->
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2" VerticalOptions="Center">
                            <Label Text="4 PICS 1 THEME"
                                   FontAttributes="Bold" FontSize="20"
                                   HorizontalOptions="Center" TextColor="#0B1D3A"
                                   CharacterSpacing="2.0"/>
                            <Label x:Name="ModuleLabel"
                                   Text="Module 1 · The Forgotten Library"
                                   FontSize="11" FontAttributes="Italic"
                                   HorizontalOptions="Center" TextColor="#1565C0"/>
                        </VerticalStackLayout>

                        <!-- Score -->
                        <Border Grid.Column="2"
                                Padding="14,8"
                                BackgroundColor="#0B1D3A"
                                Stroke="#1A3A6B" StrokeThickness="1.5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="0">
                                <Label x:Name="ScoreLabel"
                                       Text="0 pts"
                                       FontAttributes="Bold" FontSize="18"
                                       HorizontalOptions="Center" TextColor="White"/>
                                <Label Text="SCORE" CharacterSpacing="1.5"
                                       FontSize="8" FontAttributes="Bold"
                                       HorizontalOptions="Center" TextColor="#93C5FD"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── ROUND + ATTEMPTS TRACKER ── -->
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,14" ColumnSpacing="12">
                    <!-- Round pills -->
                    <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                        <Label Text="ROUND" CharacterSpacing="2.0" FontAttributes="Bold"
                               FontSize="10" TextColor="#93C5FD" VerticalOptions="Center"/>
                        <Border x:Name="Round1Pill" Padding="10,4" BackgroundColor="#1565C0" Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Label Text="1" FontAttributes="Bold" FontSize="12" TextColor="White"/>
                        </Border>
                        <Border x:Name="Round2Pill" Padding="10,4" BackgroundColor="#1A3A6B" Stroke="#2A5BAD" StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Label Text="2" FontAttributes="Bold" FontSize="12" TextColor="#93C5FD"/>
                        </Border>
                        <Border x:Name="Round3Pill" Padding="10,4" BackgroundColor="#1A3A6B" Stroke="#2A5BAD" StrokeThickness="1">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Label Text="3" FontAttributes="Bold" FontSize="12" TextColor="#93C5FD"/>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Attempts hearts -->
                    <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                        <Label Text="TRIES" CharacterSpacing="1.5" FontAttributes="Bold"
                               FontSize="10" TextColor="#93C5FD" VerticalOptions="Center"/>
                        <Label x:Name="Heart1" Text="❤️" FontSize="20"/>
                        <Label x:Name="Heart2" Text="❤️" FontSize="20"/>
                        <Label x:Name="Heart3" Text="❤️" FontSize="20"/>
                    </HorizontalStackLayout>
                </Grid>

                <!-- ── 4-IMAGE COLLAGE ── -->
                <Border Grid.Row="2"
                        Padding="0" Margin="0,0,0,18"
                        BackgroundColor="#0F1E3A"
                        Stroke="#1A3A6B" StrokeThickness="1.5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Opacity="0.30" Radius="24" Offset="0,8"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="160,160" ColumnSpacing="3" RowSpacing="3" Padding="3">
                        <!-- Image 1 -->
                        <Border Grid.Row="0" Grid.Column="0" Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="25,0,0,0"/></Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#1A3A6B"/>
                                    <GradientStop Offset="1" Color="#112554"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Image x:Name="Img1" Aspect="AspectFill" Opacity="0"/>
                                <Label x:Name="ImgLabel1" Text="🖼" FontSize="42"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                        <!-- Image 2 -->
                        <Border Grid.Row="0" Grid.Column="1" Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="0,25,0,0"/></Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#1A3A6B"/>
                                    <GradientStop Offset="1" Color="#112554"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Image x:Name="Img2" Aspect="AspectFill" Opacity="0"/>
                                <Label x:Name="ImgLabel2" Text="🖼" FontSize="42"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                        <!-- Image 3 -->
                        <Border Grid.Row="1" Grid.Column="0" Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,0,25"/></Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#1A3A6B"/>
                                    <GradientStop Offset="1" Color="#112554"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Image x:Name="Img3" Aspect="AspectFill" Opacity="0"/>
                                <Label x:Name="ImgLabel3" Text="🖼" FontSize="42"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                        <!-- Image 4 -->
                        <Border Grid.Row="1" Grid.Column="1" Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,25,0"/></Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#1A3A6B"/>
                                    <GradientStop Offset="1" Color="#112554"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Image x:Name="Img4" Aspect="AspectFill" Opacity="0"/>
                                <Label x:Name="ImgLabel4" Text="🖼" FontSize="42"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── HINT AREA ── -->
                <Border x:Name="HintBorder"
                        Grid.Row="3"
                        Padding="18,14" Margin="0,0,0,16"
                        IsVisible="False"
                        Stroke="#2A5BAD" StrokeThickness="1.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#0F1E3A"/>
                            <GradientStop Offset="1" Color="#112554"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Label x:Name="HintTitleLabel"
                               Text="💡  HINT"
                               FontAttributes="Bold" FontSize="11"
                               CharacterSpacing="2.0" TextColor="#93C5FD"/>
                        <Label x:Name="HintContentLabel"
                               Text=""
                               FontAttributes="Bold" FontSize="22"
                               TextColor="White" CharacterSpacing="6.0"
                               HorizontalOptions="Center"/>
                        <Label x:Name="HintDescLabel"
                               Text=""
                               FontSize="12" FontAttributes="Italic"
                               TextColor="#A0C4FF"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ── FEEDBACK LABEL ── -->
                <Label x:Name="FeedbackLabel"
                       Grid.Row="4"
                       Text=""
                       FontAttributes="Bold" FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,0,0,14"
                       TextColor="#60A5FA"/>

                <!-- ── INPUT + BUTTONS ── -->
                <Border Grid.Row="5"
                        Padding="24,20"
                        BackgroundColor="White"
                        Stroke="#DBEAFE" StrokeThickness="1.5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Opacity="0.12" Radius="20" Offset="0,6"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">
                        <!-- Answer entry -->
                        <Border Padding="4,0"
                                BackgroundColor="#F0F6FF"
                                Stroke="#DBEAFE" StrokeThickness="1.5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18"/>
                            </Border.StrokeShape>
                            <Entry x:Name="AnswerEntry"
                                   Placeholder="Type the theme word..."
                                   PlaceholderColor="#93C5FD"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#0B1D3A"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   BackgroundColor="Transparent"/>
                        </Border>

                        <!-- SUBMIT button -->
                        <Border Stroke="Transparent" StrokeThickness="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#1565C0"/>
                                    <GradientStop Offset="1" Color="#1E7BE0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#1565C0" Opacity="0.40" Radius="16" Offset="0,5"/>
                            </Border.Shadow>
                            <Button x:Name="SubmitButton"
                                    Text="SUBMIT ANSWER"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    CharacterSpacing="2.0"
                                    HeightRequest="54"
                                    BorderWidth="0"
                                    Clicked="OnSubmitClicked"/>
                        </Border>

                        <!-- NEXT / SKIP row -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button x:Name="NextButton"
                                    Grid.Column="0"
                                    Text="NEXT  ›"
                                    BackgroundColor="#0B1D3A"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    CharacterSpacing="1.5"
                                    HeightRequest="46"
                                    CornerRadius="20"
                                    IsVisible="False"
                                    Clicked="OnNextClicked"/>
                            <Button x:Name="SkipButton"
                                    Grid.Column="1"
                                    Text="SKIP"
                                    BackgroundColor="Transparent"
                                    TextColor="#1565C0"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    BorderColor="#DBEAFE"
                                    BorderWidth="1.5"
                                    HeightRequest="46"
                                    CornerRadius="20"
                                    Clicked="OnSkipClicked"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
