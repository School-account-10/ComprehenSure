<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="comprehensure.DASHBOARD.MiniGames.OneThemePage"
             BackgroundColor="#0B1D3A"
             Title="4 Pics 1 Theme">

    <!-- ═══════════════════════════════════════════ -->
    <!--  Background cloud ellipses                   -->
    <!-- ═══════════════════════════════════════════ -->
    <Grid>
        <Grid HorizontalOptions="Fill" InputTransparent="True" VerticalOptions="Fill">
            <Ellipse Margin="-100,-60,0,0" Fill="White" HeightRequest="240"
                     HorizontalOptions="Start" Opacity="0.06" VerticalOptions="Start" WidthRequest="360"/>
            <Ellipse Margin="80,-100,0,0" Fill="White" HeightRequest="160"
                     HorizontalOptions="Start" Opacity="0.04" VerticalOptions="Start" WidthRequest="220"/>
            <Ellipse Margin="0,-50,-80,0" Fill="White" HeightRequest="220"
                     HorizontalOptions="End" Opacity="0.06" VerticalOptions="Start" WidthRequest="320"/>
            <Ellipse Margin="0,0,-100,-60" Fill="White" HeightRequest="260"
                     HorizontalOptions="End" Opacity="0.05" VerticalOptions="End" WidthRequest="380"/>
            <Ellipse Margin="-80,0,0,-80" Fill="White" HeightRequest="200"
                     HorizontalOptions="Start" Opacity="0.04" VerticalOptions="End" WidthRequest="300"/>
            <Ellipse Margin="0,-180,0,0" Fill="#3B82F6" HeightRequest="300"
                     HorizontalOptions="Center" Opacity="0.08" VerticalOptions="Start" WidthRequest="500"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  Main layout — 4 rows, no ScrollView, fits full screen  -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16,8,16,10" RowSpacing="8">

            <!-- ── ROW 0: TOP BAR ── -->
            <Border Grid.Row="0"
                    Padding="12,8"
                    Stroke="Transparent" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0" Color="#FFFFFF"/>
                        <GradientStop Offset="1" Color="#EEF4FF"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Opacity="0.15" Radius="16" Offset="0,4"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Text="← EXIT"
                            BackgroundColor="Transparent"
                            TextColor="#1565C0"
                            FontAttributes="Bold"
                            FontSize="12"
                            BorderColor="#DBEAFE"
                            BorderWidth="1.5"
                            CornerRadius="16"
                            HeightRequest="36"
                            WidthRequest="80"
                            Clicked="OnExitClicked"/>

                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="1" VerticalOptions="Center">
                        <Label Text="4 PICS 1 THEME"
                               FontAttributes="Bold" FontSize="17"
                               HorizontalOptions="Center" TextColor="#0B1D3A"
                               CharacterSpacing="2.0"/>
                        <Label x:Name="ModuleLabel"
                               Text="Module 1 · The Forgotten Library"
                               FontSize="10" FontAttributes="Italic"
                               HorizontalOptions="Center" TextColor="#1565C0"/>
                    </VerticalStackLayout>

                    <Border Grid.Column="2"
                            Padding="12,6"
                            BackgroundColor="#0B1D3A"
                            Stroke="#1A3A6B" StrokeThickness="1.5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="0">
                            <Label x:Name="ScoreLabel"
                                   Text="0 pts"
                                   FontAttributes="Bold" FontSize="15"
                                   HorizontalOptions="Center" TextColor="White"/>
                            <Label Text="SCORE" CharacterSpacing="1.5"
                                   FontSize="7" FontAttributes="Bold"
                                   HorizontalOptions="Center" TextColor="#93C5FD"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Border>

            <!-- ── ROW 1: ROUND + TRIES ── -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                    <Label Text="ROUND" CharacterSpacing="2.0" FontAttributes="Bold"
                           FontSize="9" TextColor="#93C5FD" VerticalOptions="Center"/>
                    <Border x:Name="Round1Pill" Padding="9,3" BackgroundColor="#1565C0" Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                        <Label Text="1" FontAttributes="Bold" FontSize="11" TextColor="White"/>
                    </Border>
                    <Border x:Name="Round2Pill" Padding="9,3" BackgroundColor="#1A3A6B" Stroke="#2A5BAD" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                        <Label Text="2" FontAttributes="Bold" FontSize="11" TextColor="#93C5FD"/>
                    </Border>
                    <Border x:Name="Round3Pill" Padding="9,3" BackgroundColor="#1A3A6B" Stroke="#2A5BAD" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                        <Label Text="3" FontAttributes="Bold" FontSize="11" TextColor="#93C5FD"/>
                    </Border>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Label Text="TRIES" CharacterSpacing="1.5" FontAttributes="Bold"
                           FontSize="9" TextColor="#93C5FD" VerticalOptions="Center"/>
                    <Label x:Name="Heart1" Text="❤️" FontSize="16"/>
                    <Label x:Name="Heart2" Text="❤️" FontSize="16"/>
                    <Label x:Name="Heart3" Text="❤️" FontSize="16"/>
                </HorizontalStackLayout>
            </Grid>

            <!-- ── ROW 2: IMAGE COLLAGE (stretches to fill available space) ── -->
            <Border Grid.Row="2"
                    Padding="0" Margin="0"
                    BackgroundColor="#0F1E3A"
                    Stroke="#1A3A6B" StrokeThickness="1.5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Opacity="0.28" Radius="18" Offset="0,6"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="3" RowSpacing="3" Padding="3">
                    <Border Grid.Row="0" Grid.Column="0" Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="19,0,0,0"/></Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#1A3A6B"/>
                                <GradientStop Offset="1" Color="#112554"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Image x:Name="Img1" Aspect="AspectFill" Opacity="1"/>
                            <Label x:Name="ImgLabel1" Text="🖼" FontSize="36"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="0,19,0,0"/></Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#1A3A6B"/>
                                <GradientStop Offset="1" Color="#112554"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Image x:Name="Img2" Aspect="AspectFill" Opacity="1"/>
                            <Label x:Name="ImgLabel2" Text="🖼" FontSize="36"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="0,0,0,19"/></Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#1A3A6B"/>
                                <GradientStop Offset="1" Color="#112554"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Image x:Name="Img3" Aspect="AspectFill" Opacity="1"/>
                            <Label x:Name="ImgLabel3" Text="🖼" FontSize="36"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="0,0,19,0"/></Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#1A3A6B"/>
                                <GradientStop Offset="1" Color="#112554"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Image x:Name="Img4" Aspect="AspectFill" Opacity="1"/>
                            <Label x:Name="ImgLabel4" Text="🖼" FontSize="36"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ── ROW 3: HINT + FEEDBACK + INPUT (anchored to bottom) ── -->
            <VerticalStackLayout Grid.Row="3" Spacing="6">

                <!-- HINT AREA -->
                <Border x:Name="HintBorder"
                        Padding="14,10"
                        IsVisible="False"
                        Stroke="#2A5BAD" StrokeThickness="1.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#0F1E3A"/>
                            <GradientStop Offset="1" Color="#112554"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="HintTitleLabel"
                               Text="💡  HINT"
                               FontAttributes="Bold" FontSize="10"
                               CharacterSpacing="2.0" TextColor="#93C5FD"/>
                        <Label x:Name="HintContentLabel"
                               Text=""
                               FontAttributes="Bold" FontSize="18"
                               TextColor="White" CharacterSpacing="6.0"
                               HorizontalOptions="Center"/>
                        <Label x:Name="HintDescLabel"
                               Text=""
                               FontSize="11" FontAttributes="Italic"
                               TextColor="#A0C4FF"
                               LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Border>

                <!-- FEEDBACK LABEL -->
                <Label x:Name="FeedbackLabel"
                       Text=""
                       FontAttributes="Bold" FontSize="13"
                       HorizontalOptions="Center"
                       TextColor="#60A5FA"/>

                <!-- INPUT + BUTTONS CARD -->
                <Border Padding="12,10"
                        BackgroundColor="White"
                        Stroke="#DBEAFE" StrokeThickness="1.5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Opacity="0.10" Radius="16" Offset="0,4"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="7">
                        <Border Padding="4,0"
                                BackgroundColor="#F0F6FF"
                                Stroke="#DBEAFE" StrokeThickness="1.5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Entry x:Name="AnswerEntry"
                                   Placeholder="Type the theme word..."
                                   PlaceholderColor="#93C5FD"
                                   HorizontalTextAlignment="Center"
                                   TextColor="#0B1D3A"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   BackgroundColor="Transparent"/>
                        </Border>

                        <Border Stroke="Transparent" StrokeThickness="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#1565C0"/>
                                    <GradientStop Offset="1" Color="#1E7BE0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#1565C0" Opacity="0.35" Radius="12" Offset="0,4"/>
                            </Border.Shadow>
                            <Button x:Name="SubmitButton"
                                    Text="SUBMIT ANSWER"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    CharacterSpacing="2.0"
                                    HeightRequest="42"
                                    BorderWidth="0"
                                    Clicked="OnSubmitClicked"/>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button x:Name="NextButton"
                                    Grid.Column="0"
                                    Text="NEXT  ›"
                                    BackgroundColor="#0B1D3A"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    CharacterSpacing="1.5"
                                    HeightRequest="36"
                                    CornerRadius="16"
                                    IsVisible="False"
                                    Clicked="OnNextClicked"/>
                            <Button x:Name="SkipButton"
                                    Grid.Column="1"
                                    Text="SKIP"
                                    BackgroundColor="Transparent"
                                    TextColor="#1565C0"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    BorderColor="#DBEAFE"
                                    BorderWidth="1.5"
                                    HeightRequest="36"
                                    CornerRadius="16"
                                    Clicked="OnSkipClicked"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
