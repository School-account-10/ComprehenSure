<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="comprehensure.DASHBOARD.MainDashboard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F4F8FB">

    <ScrollView>
        <Grid
            Padding="30"
            ColumnSpacing="25"
            RowSpacing="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="25"
                BackgroundColor="White"
                StrokeThickness="0"
                VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="20">
                    <Label
                        CharacterSpacing="1"
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="MY PROFILE"
                        TextColor="#507D9B" />

                    <Border
                        HeightRequest="120"
                        HorizontalOptions="Center"
                        Stroke="#BDE0FE"
                        StrokeThickness="3"
                        WidthRequest="120">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="60" />
                        </Border.StrokeShape>
                        <ImageButton
                            Aspect="AspectFill"
                            Command="{Binding ProfileDashboardCommand}"
                            Source="user.png" />
                    </Border>

                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        HorizontalOptions="Center"
                        Text="{Binding UsernameEdit}"
                        TextColor="#1B3A57" />

                    <Button
                        BackgroundColor="Transparent"
                        BorderColor="#80c2ed"
                        BorderWidth="2"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        FontSize="14"
                        HeightRequest="40"
                        Text="Settings"
                        TextColor="#80c2ed" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="25">
                <Label
                    FontAttributes="Bold"
                    FontSize="32"
                    HorizontalOptions="Center"
                    Text="DASHBOARD"
                    TextColor="#1B3A57" />

                <Border
                    Padding="30"
                    BackgroundColor="White"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <Grid
                        HeightRequest="200"
                        HorizontalOptions="Center"
                        WidthRequest="200">
                        <Ellipse Stroke="#80c2ed" StrokeThickness="16" />
                        <Ellipse
                            x:Name="ProgressCircle"
                            Rotation="-90"
                            Stroke="#F0F4F8"
                            StrokeDashArray="100, 100"
                            StrokeDashOffset="{Binding StrokeOffset}"
                            StrokeThickness="16" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="36"
                            HorizontalOptions="Center"
                            Text="{Binding DisplayPercentage}"
                            TextColor="#1B3A57"
                            VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                    <Button
                        Grid.Column="0"
                        BackgroundColor="#BDE0FE"
                        Command="{Binding modulesCommand}"
                        CornerRadius="15"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        Shadow="{Shadow Brush=Black,
                                        Offset='0,2',
                                        Opacity=0.1}"
                        Text="MODULES"
                        TextColor="#1B3A57" />
                    <Button
                        Grid.Column="1"
                        BackgroundColor="#BDE0FE"
                        CornerRadius="15"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        Shadow="{Shadow Brush=Black,
                                        Offset='0,2',
                                        Opacity=0.1}"
                        Text="ABOUT US"
                        TextColor="#1B3A57" />
                </Grid>

                <Label
                    Margin="0,10"
                    FontAttributes="Bold"
                    FontSize="20"
                    HorizontalOptions="Center"
                    Text="CHALLENGE ZONE"
                    TextColor="#1B3A57" />

                <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                    <Frame
                        Grid.Column="0"
                        Padding="0"
                        BackgroundColor="White"
                        BorderColor="#BDE0FE"
                        CornerRadius="20"
                        HasShadow="False">
                        <VerticalStackLayout Padding="15" Spacing="10">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalOptions="Center"
                                Text="🔍 SYNONYM"
                                TextColor="#1B3A57" />
                            <Label
                                FontSize="12"
                                HorizontalOptions="Center"
                                Text="Find hidden meanings"
                                TextColor="#507D9B" />
                            <Button
                                BackgroundColor="#80c2ed"
                                Clicked="OnSynonymHuntClicked"
                                CornerRadius="12"
                                FontAttributes="Bold"
                                HeightRequest="45"
                                Text="PLAY NOW"
                                TextColor="#1B3A57" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame
                        Grid.Column="1"
                        Padding="0"
                        BackgroundColor="White"
                        BorderColor="#BDE0FE"
                        CornerRadius="20"
                        HasShadow="False">
                        <VerticalStackLayout Padding="15" Spacing="10">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalOptions="Center"
                                Text="🖼️ 1 THEME"
                                TextColor="#1B3A57" />
                            <Label
                                FontSize="12"
                                HorizontalOptions="Center"
                                Text="Connect the clues"
                                TextColor="#507D9B" />
                            <Button
                                BackgroundColor="#80c2ed"
                                Clicked="OnOneWordClicked"
                                CornerRadius="12"
                                FontAttributes="Bold"
                                HeightRequest="45"
                                Text="GUESS WORD"
                                TextColor="#1B3A57" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <Border Padding="20" BackgroundColor="#80c2ed">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Label
                        FontAttributes="Italic"
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        Text="&quot;Important truths can be found through curiosity and effort.&quot;"
                        TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <Border
                Grid.Column="2"
                Padding="25"
                BackgroundColor="White"
                StrokeThickness="0"
                VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="15">
                    <Label
                        CharacterSpacing="1"
                        FontAttributes="Bold"
                        FontSize="14"
                        HorizontalOptions="Center"
                        Text="LEADERBOARD"
                        TextColor="#507D9B" />

                    <Border
                        Padding="15"
                        BackgroundColor="#F8FBFF"
                        Stroke="#BDE0FE"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Label
                            FontAttributes="Bold"
                            FontSize="16"
                            HorizontalOptions="Center"
                            Text="1. abber"
                            TextColor="#1B3A57" />
                    </Border>

                    <Button
                        BackgroundColor="#BDE0FE"
                        Command="{Binding AddValueCommand}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        HeightRequest="45"
                        Text="Update Rank"
                        TextColor="#1B3A57" />

                    <Button
                        BackgroundColor="#F0F0F0"
                        Command="{Binding SubtractValueCommand}"
                        CornerRadius="12"
                        FontAttributes="Bold"
                        HeightRequest="45"
                        Text="Reset Score"
                        TextColor="#507D9B" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>