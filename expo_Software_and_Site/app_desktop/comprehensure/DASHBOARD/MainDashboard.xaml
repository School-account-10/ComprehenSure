<ContentPage
    x:Class="comprehensure.DASHBOARD.MainDashboard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F2F6FB"
    Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Background decorative blobs — matches ModulesDashboard exactly -->
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" InputTransparent="True">
            <Ellipse
                Fill="White"
                WidthRequest="580" HeightRequest="440"
                HorizontalOptions="Start" VerticalOptions="Start"
                Margin="-140,-110,0,0" Opacity="0.75" />
            <Ellipse
                Fill="#D6EAFF"
                WidthRequest="460" HeightRequest="380"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,-110,-60" Opacity="0.45" />
        </Grid>

        <ScrollView>
            <Grid
                Padding="36,28,36,48"
                ColumnSpacing="20"
                RowSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  ══════════════════════════════════════════  -->
                <!--  ROW 0 — HEADER CARD                        -->
                <!--  ══════════════════════════════════════════  -->
                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Padding="24,20"
                    BackgroundColor="White"
                    Stroke="#CBDCEB"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20">

                        <!--  Profile section  -->
                        <HorizontalStackLayout
                            Grid.Column="0"
                            Spacing="14"
                            VerticalOptions="Center">

                            <!--  Avatar ring  -->
                            <Border
                                BackgroundColor="#D6EAFF"
                                HeightRequest="60"
                                Stroke="#CBDCEB"
                                StrokeThickness="2"
                                WidthRequest="60">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="30" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,3" Radius="10" Opacity="0.08" />
                                </Border.Shadow>
                                <ImageButton
                                    Aspect="AspectFill"
                                    Command="{Binding ProfileDashboardCommand}"
                                    Source="user.png" />
                            </Border>

                            <!--  Name + greeting  -->
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label
                                    CharacterSpacing="2.0"
                                    FontAttributes="Bold"
                                    FontSize="9"
                                    Text="WELCOME BACK,"
                                    TextColor="#6B8CAE" />
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="20"
                                    Text="{Binding UsernameEdit}"
                                    TextColor="#0F2D4A" />
                            </VerticalStackLayout>

                            <!--  Settings icon  -->
                            <ImageButton
                                Margin="4,0,0,0"
                                Command="{Binding SettingsCommand}"
                                HeightRequest="32"
                                Opacity="0.45"
                                Source="settings.png"
                                VerticalOptions="Center"
                                WidthRequest="32" />
                        </HorizontalStackLayout>

                        <!--  Centre title  -->
                        <VerticalStackLayout
                            Grid.Column="1"
                            HorizontalOptions="FillAndExpand"
                            Spacing="2"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="30"
                                HorizontalOptions="Fill"
                                HorizontalTextAlignment="Center"
                                CharacterSpacing="1.5"
                                Text="Dashboard"
                                TextColor="#0F2D4A" />
                            <Label
                                FontAttributes="Italic"
                                FontSize="13"
                                HorizontalOptions="Fill"
                                HorizontalTextAlignment="Center"
                                Text="comprehensure"
                                TextColor="#6B8CAE" />
                        </VerticalStackLayout>

                        <!--  Progress ring card  -->
                        <Border
                            Grid.Column="2"
                            Padding="20,16"
                            BackgroundColor="White"
                            HorizontalOptions="End"
                            Stroke="#CBDCEB"
                            StrokeThickness="1"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,4" Radius="16" Opacity="0.07" />
                            </Border.Shadow>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                                <Grid
                                    HeightRequest="120"
                                    HorizontalOptions="Center"
                                    WidthRequest="120">
                                    <!--  Track ring (full circle background) -->
                                    <Ellipse
                                        Fill="Transparent"
                                        Stroke="#D6EAFF"
                                        StrokeThickness="14" />
                                    <!--  Progress fill arc  -->
                                    <Ellipse
                                        x:Name="DashboardProgressCircle"
                                        Fill="Transparent"
                                        Rotation="-90"
                                        Stroke="#0F2D4A"
                                        StrokeDashArray="100,100"
                                        StrokeDashOffset="{Binding StrokeOffset}"
                                        StrokeThickness="14" />
                                    <!--  Percentage label  -->
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="24"
                                        HorizontalOptions="Center"
                                        Text="{Binding DisplayPercentage}"
                                        TextColor="#0F2D4A"
                                        VerticalOptions="Center" />
                                </Grid>
                                <Label
                                    CharacterSpacing="1.8"
                                    FontAttributes="Bold"
                                    FontSize="8"
                                    HorizontalOptions="Center"
                                    Text="OVERALL PROGRESS"
                                    TextColor="#6B8CAE" />
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </Border>

                <!--  ══════════════════════════════════════════  -->
                <!--  ROW 1 — NAV BUTTONS                        -->
                <!--  ══════════════════════════════════════════  -->

                <!--  ★ MODULES — hero primary button  -->
                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    BackgroundColor="#0F2D4A"
                    Stroke="Transparent"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,12" Radius="32" Opacity="0.28" />
                    </Border.Shadow>

                    <Grid RowDefinitions="Auto,Auto" RowSpacing="0">
                        <!--  "START LEARNING" pill badge  -->
                        <Border
                            Grid.Row="0"
                            Margin="0,12,0,0"
                            Padding="12,4"
                            HorizontalOptions="Center"
                            Stroke="#EBBF0C"
                            StrokeThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="#EBBF0C" />
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Label
                                CharacterSpacing="2.5"
                                FontAttributes="Bold"
                                FontSize="9"
                                HorizontalOptions="Center"
                                Text="★  START LEARNING"
                                TextColor="#FFFFFF" />
                        </Border>
                        <Button
                            Grid.Row="1"
                            BackgroundColor="Transparent"
                            BorderWidth="0"
                            CharacterSpacing="3.5"
                            Command="{Binding modulesCommand}"
                            FontAttributes="Bold"
                            FontSize="26"
                            HeightRequest="80"
                            Text="📚  MODULES"
                            TextColor="White" />
                    </Grid>
                </Border>

                <!--  ABOUT US button  -->
                <Border
                    Grid.Row="1"
                    Grid.Column="2"
                    BackgroundColor="White"
                    Stroke="#CBDCEB"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,4" Radius="12" Opacity="0.07" />
                    </Border.Shadow>
                    <Button
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        CharacterSpacing="2.0"
                        FontAttributes="Bold"
                        FontSize="15"
                        HeightRequest="88"
                        Text="ABOUT US"
                        TextColor="#0F2D4A" />
                </Border>

                <!--  ══════════════════════════════════════════  -->
                <!--  MASTER DICTIONARY BUTTON                   -->
                <!--  ══════════════════════════════════════════  -->
                <Border
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,12,0,0"
                    Stroke="#1E3A6B"
                    StrokeThickness="1.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0A0F1E" Offset="0"/>
                            <GradientStop Color="#0F1A30" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#4A90D9" Offset="0,6" Radius="20" Opacity="0.18"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="20,16" ColumnSpacing="16">
                        <!-- Book icon chip -->
                        <Border Grid.Column="0"
                                BackgroundColor="#0F1A30"
                                Stroke="#1E3A6B" StrokeThickness="1"
                                HeightRequest="52" WidthRequest="52">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="26"/>
                            </Border.StrokeShape>
                            <Label Text="📚" FontSize="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <!-- Text -->
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="MASTER DICTIONARY"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="#4A90D9" CharacterSpacing="2.2"/>
                            <Label Text="All words from Modules 1–8"
                                   FontSize="13" TextColor="#4A6A9A"/>
                            <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                                <Border BackgroundColor="#1B4A1B" Stroke="#2E7D32" StrokeThickness="1" Padding="8,3">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Label Text="🟢 Easy" FontSize="10" FontAttributes="Bold" TextColor="#A5D6A7"/>
                                </Border>
                                <Border BackgroundColor="#3D3200" Stroke="#F9A825" StrokeThickness="1" Padding="8,3">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Label Text="🟡 Average" FontSize="10" FontAttributes="Bold" TextColor="#FFE082"/>
                                </Border>
                                <Border BackgroundColor="#4A0F0F" Stroke="#C62828" StrokeThickness="1" Padding="8,3">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Label Text="🔴 Intermediate" FontSize="10" FontAttributes="Bold" TextColor="#EF9A9A"/>
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMasterDictionaryClicked"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <!--  ══════════════════════════════════════════  -->
                <!--  ROW 2 — CHALLENGE ZONE (left+mid cols)     -->
                <!--  ══════════════════════════════════════════  -->
                <VerticalStackLayout
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Spacing="16">

                    <!--  Section heading  -->
                    <HorizontalStackLayout Margin="4,0" Spacing="10">
                        <BoxView
                            BackgroundColor="#0F2D4A"
                            CornerRadius="2"
                            HeightRequest="20"
                            VerticalOptions="Center"
                            WidthRequest="4" />
                        <Label
                            CharacterSpacing="2.2"
                            FontAttributes="Bold"
                            FontSize="12"
                            Text="CHALLENGE ZONE"
                            TextColor="#0F2D4A"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!--  Challenge cards row  -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="16">

                        <!--  SYNONYM HUNT card  -->
                        <Border
                            Grid.Column="0"
                            Padding="0,0,0,24"
                            BackgroundColor="White"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="28" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="0">

                                <!--  Thumbnail  -->
                                <Border
                                    HeightRequest="290"
                                    Stroke="Transparent"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="28,28,0,0" />
                                    </Border.StrokeShape>
                                    <Image
                                        Aspect="AspectFill"
                                        Opacity="1"
                                        Source="synonym_thumb.png"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </Border>

                                <!--  Card content  -->
                                <VerticalStackLayout Margin="22,16,22,0" HorizontalOptions="Center" Spacing="10">
                                    <Label
                                        CharacterSpacing="1.5"
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        HorizontalOptions="Center"
                                        Text="SYNONYM HUNT"
                                        TextColor="#0F2D4A" />
                                    <Label
                                        FontSize="12"
                                        HorizontalTextAlignment="Center"
                                        LineBreakMode="WordWrap"
                                        Text="Match words with the same meaning"
                                        TextColor="#6B8CAE" />
                                    <Border
                                        BackgroundColor="#0F2D4A"
                                        Stroke="Transparent"
                                        StrokeThickness="0"
                                        Margin="0,4,0,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="26" />
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                        </Border.Shadow>
                                        <Button
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            CharacterSpacing="1.0"
                                            Clicked="OnSynonymHuntClicked"
                                            FontAttributes="Bold"
                                            FontSize="13"
                                            HeightRequest="52"
                                            Text="PLAY"
                                            TextColor="White" />
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!--  4 PICS 1 THEME card  -->
                        <Border
                            Grid.Column="1"
                            Padding="0,0,0,24"
                            BackgroundColor="White"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="28" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="0">

                                <!--  Thumbnail  -->
                                <Border
                                    HeightRequest="290"
                                    Stroke="Transparent"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="28,28,0,0" />
                                    </Border.StrokeShape>
                                    <Image
                                        Aspect="AspectFill"
                                        Opacity="1"
                                        Source="theme_thumb.png"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </Border>

                                <!--  Card content  -->
                                <VerticalStackLayout Margin="22,16,22,0" HorizontalOptions="Center" Spacing="10">
                                    <Label
                                        CharacterSpacing="1.5"
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        HorizontalOptions="Center"
                                        Text="4 PICS 1 THEME"
                                        TextColor="#0F2D4A" />
                                    <Label
                                        FontSize="12"
                                        HorizontalTextAlignment="Center"
                                        LineBreakMode="WordWrap"
                                        Text="Guess the theme from four image clues"
                                        TextColor="#6B8CAE" />
                                    <Border
                                        BackgroundColor="#0F2D4A"
                                        Stroke="Transparent"
                                        StrokeThickness="0"
                                        Margin="0,4,0,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="26" />
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                                        </Border.Shadow>
                                        <Button
                                            BackgroundColor="Transparent"
                                            BorderWidth="0"
                                            CharacterSpacing="1.0"
                                            Clicked="OnOneWordClicked"
                                            FontAttributes="Bold"
                                            FontSize="13"
                                            HeightRequest="52"
                                            Text="GUESS"
                                            TextColor="White" />
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                    <!--  Quote card  -->
                    <Border
                        Padding="28,22"
                        BackgroundColor="White"
                        Stroke="#CBDCEB"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,4" Radius="12" Opacity="0.06" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                            <Label
                                Grid.Column="0"
                                Margin="0,-8,0,0"
                                FontSize="52"
                                Opacity="0.15"
                                Text="&#x201C;"
                                TextColor="#0F2D4A"
                                VerticalOptions="Start" />  
                            <Label
                                Grid.Column="1"
                                FontAttributes="Italic"
                                FontSize="14"
                                LineBreakMode="WordWrap"
                                Text="placeholder"
                                TextColor="#6B8CAE"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!--  ══════════════════════════════════════════  -->
                <!--  ROW 2 — LEADERBOARD (right col)            -->
                <!--  ══════════════════════════════════════════  -->
                <Border
                    Grid.Row="3"
                    Grid.Column="2"
                    Padding="24,24"
                    BackgroundColor="White"
                    Stroke="#CBDCEB"
                    StrokeThickness="1"
                    VerticalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.07" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">

                        <!--  Heading  -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Label
                                FontSize="15"
                                Text="🏆"
                                VerticalOptions="Center" />
                            <Label
                                CharacterSpacing="2.4"
                                FontAttributes="Bold"
                                FontSize="11"
                                Text="LEADERBOARD"
                                TextColor="#0F2D4A"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!--  Divider  -->
                        <BoxView
                            Margin="0,0,0,2"
                            BackgroundColor="#CBDCEB"
                            HeightRequest="1" />

                        <!--  First place  -->
                        <Border
                            Padding="18,14"
                            BackgroundColor="#D6EAFF"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    FontSize="20"
                                    Text="🥇"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    FontSize="16"
                                    Text="{Binding FirstPlayerName}"
                                    TextColor="#0F2D4A"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="2"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding FirstPlayerScore}"
                                    TextColor="#6B8CAE"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  Second place  -->
                        <Border
                            Padding="16,12"
                            BackgroundColor="White"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    FontSize="16"
                                    Text="🥈"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="1"
                                    FontSize="14"
                                    Text="{Binding SecondPlayerName}"
                                    TextColor="#0F2D4A"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="2"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding SecondPlayerScore}"
                                    TextColor="#6B8CAE"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  Third place  -->
                        <Border
                            Padding="16,12"
                            BackgroundColor="White"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    FontSize="16"
                                    Text="🥉"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="1"
                                    FontSize="14"
                                    Text="{Binding ThirdPlayerName}"
                                    TextColor="#0F2D4A"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="2"
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding ThirdPlayerScore}"
                                    TextColor="#6B8CAE"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  Divider  -->
                        <BoxView BackgroundColor="#CBDCEB" HeightRequest="1" />

                        <!--  Increase Score  -->
                        <Border
                            BackgroundColor="#0F2D4A"
                            Stroke="Transparent"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="26" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,5" Radius="14" Opacity="0.22" />
                            </Border.Shadow>
                            <Button
                                BackgroundColor="Transparent"
                                BorderWidth="0"
                                CharacterSpacing="0.8"
                                Command="{Binding AddValueCommand}"
                                FontAttributes="Bold"
                                FontSize="13"
                                HeightRequest="52"
                                Text="▲  Increase Score"
                                TextColor="White" />
                        </Border>

                        <!--  Decrease Score  -->
                        <Border
                            BackgroundColor="White"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="26" />
                            </Border.StrokeShape>
                            <Button
                                BackgroundColor="Transparent"
                                BorderWidth="0"
                                CharacterSpacing="0.8"
                                Command="{Binding SubtractValueCommand}"
                                FontAttributes="Bold"
                                FontSize="13"
                                HeightRequest="52"
                                Text="▼  Decrease Score"
                                TextColor="#0F2D4A" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
