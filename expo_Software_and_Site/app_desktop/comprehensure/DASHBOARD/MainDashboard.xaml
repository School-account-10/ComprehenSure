<ContentPage
    x:Class="comprehensure.DASHBOARD.MainDashboard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F2F6FB">

    <Grid>

        <!--  Background decorative blobs  -->
        <Grid
            HorizontalOptions="Fill"
            InputTransparent="True"
            VerticalOptions="Fill">
            <Ellipse
                Margin="-140,-110,0,0"
                Fill="White"
                HeightRequest="440"
                HorizontalOptions="Start"
                Opacity="0.75"
                VerticalOptions="Start"
                WidthRequest="580" />
            <Ellipse
                Margin="0,0,-110,-60"
                Fill="#D6EAFF"
                HeightRequest="380"
                HorizontalOptions="End"
                Opacity="0.45"
                VerticalOptions="End"
                WidthRequest="460" />
        </Grid>

        <ScrollView>
            <Grid
                Padding="40,36,40,56"
                ColumnSpacing="24"
                RowSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  ══════════════════════════════════════════  -->
                <!--  ROW 0 — HEADER CARD  -->
                <!--  ══════════════════════════════════════════  -->
                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Padding="32,28"
                    BackgroundColor="White"
                    Stroke="#CBDCEB"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow
                            Brush="#0F2D4A"
                            Opacity="0.07"
                            Radius="36"
                            Offset="0,10" />
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="28">

                        <!--  Profile section  -->
                        <HorizontalStackLayout
                            Grid.Column="0"
                            Spacing="20"
                            VerticalOptions="Center">

                            <!--  Avatar ring  -->
                            <Border
                                BackgroundColor="#EBF4FF"
                                HeightRequest="90"
                                Stroke="#CBDCEB"
                                StrokeThickness="1.5"
                                WidthRequest="90">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="45" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow
                                        Brush="#0F2D4A"
                                        Opacity="0.10"
                                        Radius="14"
                                        Offset="0,4" />
                                </Border.Shadow>
                                <ImageButton
                                    Aspect="AspectFill"
                                    Command="{Binding ProfileDashboardCommand}"
                                    Source="user.png" />
                            </Border>

                            <!--  Name + settings  -->
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label
                                    CharacterSpacing="2.0"
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    Text="WELCOME BACK,"
                                    TextColor="#2E6BA8" />
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="28"
                                    Text="{Binding UsernameEdit}"
                                    TextColor="#0F2D4A" />
                                <Button
                                    Margin="0,10,0,0"
                                    Padding="18,0"
                                    BackgroundColor="#FAF0CA"
                                    BorderColor="#E8C547"
                                    BorderWidth="1.5"
                                    CornerRadius="17"
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    HeightRequest="34"
                                    Text="Settings"
                                    TextColor="#3a2e00" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <!--  Centre title  -->
                        <VerticalStackLayout
                            Grid.Column="1"
                            HorizontalOptions="Center"
                            Spacing="4"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="36"
                                HorizontalOptions="Center"
                                Text="Dashboard"
                                TextColor="#0F2D4A" />
                            <Label
                                CharacterSpacing="1.5"
                                FontAttributes="Italic"
                                FontSize="12"
                                HorizontalOptions="Center"
                                Text="comprehensure"
                                TextColor="#6B8CAE" />
                        </VerticalStackLayout>

                        <!--  Progress ring card  -->
                        <Border
                            Grid.Column="2"
                            Padding="24,20"
                            BackgroundColor="White"
                            HorizontalOptions="End"
                            Stroke="#CBDCEB"
                            StrokeThickness="1"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24" />
                            </Border.StrokeShape>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                                <Grid
                                    HeightRequest="150"
                                    HorizontalOptions="Center"
                                    WidthRequest="150">
                                    <!--  Track ring (dark base)  -->
                                    <Ellipse
                                        Margin="6"
                                        Stroke="#0F2D4A"
                                        StrokeThickness="13" />
                                    <!--  Progress fill ring  -->
                                    <Ellipse
                                        x:Name="DashboardProgressCircle"
                                        Margin="6"
                                        Rotation="-90"
                                        Stroke="#EBF4FF"
                                        StrokeDashArray="100,100"
                                        StrokeDashOffset="{Binding StrokeOffset}"
                                        StrokeThickness="13" />
                                    <!--  Percentage label  -->
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="30"
                                        HorizontalOptions="Center"
                                        Text="{Binding DisplayPercentage}"
                                        TextColor="#0F2D4A"
                                        VerticalOptions="Center" />
                                </Grid>
                                <Label
                                    CharacterSpacing="1.6"
                                    FontAttributes="Bold"
                                    FontSize="9"
                                    HorizontalOptions="Center"
                                    Text="OVERALL PROGRESS"
                                    TextColor="#6B8CAE" />
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </Border>

                <!--  ══════════════════════════════════════════  -->
                <!--  ROW 1 — NAV BUTTONS  -->
                <!--  ══════════════════════════════════════════  -->

                <!--  MODULES button  -->
                <Border
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    BackgroundColor="#0F2D4A"
                    Stroke="Transparent"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="36" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow
                            Brush="#0F2D4A"
                            Opacity="0.25"
                            Radius="24"
                            Offset="0,8" />
                    </Border.Shadow>
                    <Button
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        CharacterSpacing="2.0"
                        Command="{Binding modulesCommand}"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="68"
                        Text="MODULES"
                        TextColor="White" />
                </Border>

                <!--  ABOUT US button  -->
                <Border
                    Grid.Row="1"
                    Grid.Column="2"
                    BackgroundColor="#0F2D4A"
                    Stroke="Transparent"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="36" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow
                            Brush="#0F2D4A"
                            Opacity="0.25"
                            Radius="24"
                            Offset="0,8" />
                    </Border.Shadow>
                    <Button
                        BackgroundColor="Transparent"
                        BorderWidth="0"
                        CharacterSpacing="2.0"
                        FontAttributes="Bold"
                        FontSize="16"
                        HeightRequest="68"
                        Text="ABOUT US"
                        TextColor="White" />
                </Border>

                <!--  ══════════════════════════════════════════  -->
                <!--  ROW 2 — CHALLENGE ZONE (left+mid cols)  -->
                <!--  ══════════════════════════════════════════  -->
                <VerticalStackLayout
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Spacing="20">

                    <!--  Section heading  -->
                    <HorizontalStackLayout Margin="6,0" Spacing="10">
                        <BoxView
                            BackgroundColor="#0F2D4A"
                            CornerRadius="2"
                            HeightRequest="22"
                            VerticalOptions="Center"
                            WidthRequest="4" />
                        <Label
                            CharacterSpacing="2.2"
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="CHALLENGE ZONE"
                            TextColor="#0F2D4A"
                            VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!--  Challenge cards row  -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="20">

                        <!--  SYNONYM card  -->
                        <Border
                            Grid.Column="0"
                            Padding="30,28"
                            BackgroundColor="White"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="36" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow
                                    Brush="#0F2D4A"
                                    Opacity="0.06"
                                    Radius="20"
                                    Offset="0,6" />
                            </Border.Shadow>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="14">

                                <!--  Icon chip  -->
                                <Border
                                    Padding="14,10"
                                    BackgroundColor="#EBF4FF"
                                    HorizontalOptions="Center"
                                    Stroke="Transparent"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Label
                                        FontSize="28"
                                        HorizontalOptions="Center"
                                        Text="🔍" />
                                </Border>

                                <Label
                                    CharacterSpacing="1.5"
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    HorizontalOptions="Center"
                                    Text="SYNONYM"
                                    TextColor="#0F2D4A" />
                                <Label
                                    FontSize="12"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    Text="Match words with the same meaning"
                                    TextColor="#6B8CAE" />
                                <Button
                                    BackgroundColor="#FAF0CA"
                                    BorderColor="#E8C547"
                                    BorderWidth="1.5"
                                    CharacterSpacing="1.2"
                                    Clicked="OnSynonymHuntClicked"
                                    CornerRadius="22"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    HeightRequest="48"
                                    Text="PLAY"
                                    TextColor="#2a2000" />
                            </VerticalStackLayout>
                        </Border>

                        <!--  1 THEME card  -->
                        <Border
                            Grid.Column="1"
                            Padding="30,28"
                            BackgroundColor="White"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="36" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow
                                    Brush="#0F2D4A"
                                    Opacity="0.06"
                                    Radius="20"
                                    Offset="0,6" />
                            </Border.Shadow>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="14">

                                <!--  Icon chip  -->
                                <Border
                                    Padding="14,10"
                                    BackgroundColor="#EBF4FF"
                                    HorizontalOptions="Center"
                                    Stroke="Transparent"
                                    StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Label
                                        FontSize="28"
                                        HorizontalOptions="Center"
                                        Text="🖼️" />
                                </Border>

                                <Label
                                    CharacterSpacing="1.5"
                                    FontAttributes="Bold"
                                    FontSize="15"
                                    HorizontalOptions="Center"
                                    Text="1 THEME"
                                    TextColor="#0F2D4A" />
                                <Label
                                    FontSize="12"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    Text="Guess the theme from one image clue"
                                    TextColor="#6B8CAE" />
                                <Button
                                    BackgroundColor="#FAF0CA"
                                    BorderColor="#E8C547"
                                    BorderWidth="1.5"
                                    CharacterSpacing="1.2"
                                    Clicked="OnOneWordClicked"
                                    CornerRadius="22"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    HeightRequest="48"
                                    Text="GUESS"
                                    TextColor="#2a2000" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!--  Quote card  -->
                    <Border
                        Padding="32,28"
                        Stroke="#CBDCEB"
                        StrokeThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0" Color="#EBF4FF" />
                                <GradientStop Offset="1" Color="#F4F8FC" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="32" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="14">
                            <Label
                                Grid.Column="0"
                                Margin="0,-8,0,0"
                                FontSize="60"
                                Opacity="0.25"
                                Text="&#x201C;"
                                TextColor="#2E6BA8"
                                VerticalOptions="Start" />
                            <Label
                                Grid.Column="1"
                                FontAttributes="Italic"
                                FontSize="16"
                                LineBreakMode="WordWrap"
                                Text="Important truths can be found through curiosity and effort."
                                TextColor="#0F2D4A"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!--  ══════════════════════════════════════════  -->
                <!--  ROW 2 — LEADERBOARD (right col)  -->
                <!--  ══════════════════════════════════════════  -->
                <Border
                    Grid.Row="2"
                    Grid.Column="2"
                    Padding="32,30"
                    BackgroundColor="White"
                    Stroke="#CBDCEB"
                    StrokeThickness="1"
                    VerticalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow
                            Brush="#0F2D4A"
                            Opacity="0.07"
                            Radius="24"
                            Offset="0,6" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <!--  Heading  -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Label
                                FontSize="16"
                                Text="🏆"
                                VerticalOptions="Center" />
                            <Label
                                CharacterSpacing="2.6"
                                FontAttributes="Bold"
                                FontSize="11"
                                Text="LEADERBOARD"
                                TextColor="#0F2D4A"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!--  Divider  -->
                        <BoxView
                            Margin="0,0,0,4"
                            BackgroundColor="#CBDCEB"
                            HeightRequest="1" />

                        <!--  Top entry highlight first  -->
                        <Border
                            Padding="20,16"
                            Stroke="#E8C547"
                            StrokeThickness="1.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#FFF8DC" />
                                    <GradientStop Offset="1" Color="#FAF0CA" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    FontSize="22"
                                    Text="🥇"
                                    VerticalOptions="Center" />
                                <!--  name  -->
                                <Label
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    FontSize="20"
                                    Text="{Binding FirstPlayerName}"
                                    TextColor="#0F2D4A"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="2"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Text="{Binding FirstPlayerScore}"
                                    TextColor="#6B8CAE"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  Secondary entries second  -->
                        <Border
                            Padding="18,14"
                            BackgroundColor="#F2F6FB"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <!--  name  -->
                                <Label
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    FontSize="18"
                                    Text="🥈"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="1"
                                    FontSize="16"
                                    Text="{Binding SecondPlayerName}"
                                    TextColor="#6B8CAE"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="2"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Text="{Binding SecondPlayerScore}"
                                    TextColor="#6B8CAE"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                        <!--  Secondary entries third  -->
                        <Border
                            Padding="18,14"
                            BackgroundColor="#F2F6FB"
                            Stroke="#CBDCEB"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    FontSize="18"
                                    Text="🥉"
                                    VerticalOptions="Center" />
                                <!--  name  -->
                                
                                <Label
                                    Grid.Column="1"
                                    FontSize="16"
                                    Text="{Binding ThirdPlayerName}"
                                    TextColor="#6B8CAE"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="2"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Text="{Binding ThirdPlayerScore}"
                                    TextColor="#6B8CAE"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!--  Divider  -->
                        <BoxView BackgroundColor="#CBDCEB" HeightRequest="1" />

                        <!--  Score controls  -->
                        <Border
                            BackgroundColor="#0F2D4A"
                            Stroke="Transparent"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="28" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow
                                    Brush="#0F2D4A"
                                    Opacity="0.22"
                                    Radius="18"
                                    Offset="0,6" />
                            </Border.Shadow>
                            <Button
                                BackgroundColor="Transparent"
                                BorderWidth="0"
                                CharacterSpacing="0.8"
                                Command="{Binding AddValueCommand}"
                                FontAttributes="Bold"
                                FontSize="14"
                                HeightRequest="54"
                                Text="▲  Increase Score"
                                TextColor="White" />
                        </Border>

                        <Border
                            BackgroundColor="Transparent"
                            Stroke="#CBDCEB"
                            StrokeThickness="1.5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="28" />
                            </Border.StrokeShape>
                            <Button
                                BackgroundColor="Transparent"
                                BorderWidth="0"
                                CharacterSpacing="0.8"
                                Command="{Binding SubtractValueCommand}"
                                FontAttributes="Bold"
                                FontSize="14"
                                HeightRequest="54"
                                Text="▼  Decrease Score"
                                TextColor="#0F2D4A" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
