<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="comprehensure.DASHBOARD.MainDashboard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F2F6FB">

    <Grid>

        <!-- Background decorative blobs -->
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" InputTransparent="True">
            <Ellipse Fill="White"    WidthRequest="580" HeightRequest="440"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="-140,-110,0,0" Opacity="0.75" />
            <Ellipse Fill="#D6EAFF" WidthRequest="460" HeightRequest="380"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-110,-60" Opacity="0.45" />
        </Grid>

        <ScrollView>
            <Grid Padding="40,36,40,56" ColumnSpacing="24" RowSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ══════════════════════════════════════════ -->
                <!--  ROW 0 — HEADER CARD                      -->
                <!-- ══════════════════════════════════════════ -->
                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                        Padding="32,28" BackgroundColor="White"
                        Stroke="#CBDCEB" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,10" Radius="36" Opacity="0.07" />
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="28">

                        <!-- Profile section -->
                        <HorizontalStackLayout Grid.Column="0" Spacing="20" VerticalOptions="Center">

                            <!-- Avatar ring -->
                            <Border HeightRequest="90" WidthRequest="90"
                                    Stroke="#CBDCEB" StrokeThickness="1.5"
                                    BackgroundColor="#EBF4FF">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="45" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#0F2D4A" Offset="0,4" Radius="14" Opacity="0.10" />
                                </Border.Shadow>
                                <ImageButton Command="{Binding ProfileDashboardCommand}"
                                             Source="user.png" Aspect="AspectFill" />
                            </Border>

                            <!-- Name + settings -->
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="WELCOME BACK,"
                                       FontSize="10" FontAttributes="Bold"
                                       TextColor="#2E6BA8" CharacterSpacing="2.0" />
                                <Label Text="{Binding UsernameEdit}"
                                       FontSize="28" FontAttributes="Bold"
                                       TextColor="#0F2D4A" />
                                <Button Text="Settings"
                                        FontSize="11" FontAttributes="Bold"
                                        HeightRequest="34" Padding="18,0"
                                        BackgroundColor="#FAF0CA" TextColor="#3a2e00"
                                        BorderColor="#E8C547" BorderWidth="1.5"
                                        CornerRadius="17" Margin="0,10,0,0" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <!-- Centre title -->
                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="4">
                            <Label Text="Dashboard"
                                   FontSize="36" FontAttributes="Bold"
                                   TextColor="#0F2D4A"
                                   HorizontalOptions="Center" />
                            <Label Text="comprehensure"
                                   FontSize="12" FontAttributes="Italic"
                                   TextColor="#6B8CAE" CharacterSpacing="1.5"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>

                        <!-- Progress ring card -->
                        <Border Grid.Column="2"
                                Padding="24,20" BackgroundColor="White"
                                Stroke="#CBDCEB" StrokeThickness="1"
                                VerticalOptions="Center" HorizontalOptions="End">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Grid HeightRequest="150" WidthRequest="150" HorizontalOptions="Center">
                                    <!-- Track ring (dark base) -->
                                    <Ellipse Stroke="#0F2D4A" StrokeThickness="13"
                                             Margin="6" />
                                    <!-- Progress fill ring -->
                                    <Ellipse x:Name="DashboardProgressCircle"
                                             Rotation="-90"
                                             Stroke="#EBF4FF"
                                             StrokeDashArray="100,100"
                                             StrokeDashOffset="{Binding StrokeOffset}"
                                             StrokeThickness="13"
                                             Margin="6" />
                                    <!-- Percentage label -->
                                    <Label Text="{Binding DisplayPercentage}"
                                           FontSize="30" FontAttributes="Bold"
                                           TextColor="#0F2D4A"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Grid>
                                <Label Text="OVERALL PROGRESS"
                                       FontSize="9" FontAttributes="Bold"
                                       TextColor="#6B8CAE" CharacterSpacing="1.6"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════ -->
                <!--  ROW 1 — NAV BUTTONS                      -->
                <!-- ══════════════════════════════════════════ -->

                <!-- MODULES button -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        BackgroundColor="#0F2D4A" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="36" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.25" />
                    </Border.Shadow>
                    <Button Text="MODULES"
                            Command="{Binding modulesCommand}"
                            BackgroundColor="Transparent"
                            TextColor="White" FontAttributes="Bold" FontSize="16"
                            CharacterSpacing="2.0"
                            HeightRequest="68" BorderWidth="0" />
                </Border>

                <!-- ABOUT US button -->
                <Border Grid.Row="1" Grid.Column="2"
                        BackgroundColor="#0F2D4A" Stroke="Transparent" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="36" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,8" Radius="24" Opacity="0.25" />
                    </Border.Shadow>
                    <Button Text="ABOUT US"
                            BackgroundColor="Transparent"
                            TextColor="White" FontAttributes="Bold" FontSize="16"
                            CharacterSpacing="2.0"
                            HeightRequest="68" BorderWidth="0" />
                </Border>

                <!-- ══════════════════════════════════════════ -->
                <!--  ROW 2 — CHALLENGE ZONE (left+mid cols)   -->
                <!-- ══════════════════════════════════════════ -->
                <VerticalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="20">

                    <!-- Section heading -->
                    <HorizontalStackLayout Spacing="10" Margin="6,0">
                        <BoxView WidthRequest="4" HeightRequest="22" CornerRadius="2"
                                 BackgroundColor="#0F2D4A" VerticalOptions="Center" />
                        <Label Text="CHALLENGE ZONE"
                               FontAttributes="Bold" FontSize="13"
                               TextColor="#0F2D4A" CharacterSpacing="2.2"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Challenge cards row -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="20">

                        <!-- SYNONYM card -->
                        <Border Grid.Column="0"
                                Padding="30,28" BackgroundColor="White"
                                Stroke="#CBDCEB" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="36" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,6" Radius="20" Opacity="0.06" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="14" HorizontalOptions="Center">

                                <!-- Icon chip -->
                                <Border BackgroundColor="#EBF4FF" Stroke="Transparent"
                                        StrokeThickness="0" Padding="14,10"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Label Text="🔍" FontSize="28" HorizontalOptions="Center" />
                                </Border>

                                <Label Text="SYNONYM" FontAttributes="Bold" FontSize="15"
                                       TextColor="#0F2D4A" HorizontalOptions="Center"
                                       CharacterSpacing="1.5" />
                                <Label Text="Match words with the same meaning"
                                       FontSize="12" TextColor="#6B8CAE"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="WordWrap" />
                                <Button Text="PLAY"
                                        Clicked="OnSynonymHuntClicked"
                                        BackgroundColor="#FAF0CA" TextColor="#2a2000"
                                        BorderColor="#E8C547" BorderWidth="1.5"
                                        CornerRadius="22" HeightRequest="48"
                                        FontAttributes="Bold" FontSize="13"
                                        CharacterSpacing="1.2" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- 1 THEME card -->
                        <Border Grid.Column="1"
                                Padding="30,28" BackgroundColor="White"
                                Stroke="#CBDCEB" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="36" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,6" Radius="20" Opacity="0.06" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="14" HorizontalOptions="Center">

                                <!-- Icon chip -->
                                <Border BackgroundColor="#EBF4FF" Stroke="Transparent"
                                        StrokeThickness="0" Padding="14,10"
                                        HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18" />
                                    </Border.StrokeShape>
                                    <Label Text="🖼️" FontSize="28" HorizontalOptions="Center" />
                                </Border>

                                <Label Text="1 THEME" FontAttributes="Bold" FontSize="15"
                                       TextColor="#0F2D4A" HorizontalOptions="Center"
                                       CharacterSpacing="1.5" />
                                <Label Text="Guess the theme from one image clue"
                                       FontSize="12" TextColor="#6B8CAE"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="WordWrap" />
                                <Button Text="GUESS"
                                        Clicked="OnOneWordClicked"
                                        BackgroundColor="#FAF0CA" TextColor="#2a2000"
                                        BorderColor="#E8C547" BorderWidth="1.5"
                                        CornerRadius="22" HeightRequest="48"
                                        FontAttributes="Bold" FontSize="13"
                                        CharacterSpacing="1.2" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Quote card -->
                    <Border Padding="32,28" Stroke="#CBDCEB" StrokeThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EBF4FF" Offset="0" />
                                <GradientStop Color="#F4F8FC" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="32" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="14">
                            <Label Grid.Column="0"
                                   Text="&#x201C;"
                                   FontSize="60" TextColor="#2E6BA8"
                                   Opacity="0.25"
                                   VerticalOptions="Start"
                                   Margin="0,-8,0,0" />
                            <Label Grid.Column="1"
                                   Text="Important truths can be found through curiosity and effort."
                                   FontAttributes="Italic" FontSize="16"
                                   TextColor="#0F2D4A" LineBreakMode="WordWrap"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- ══════════════════════════════════════════ -->
                <!--  ROW 2 — LEADERBOARD (right col)          -->
                <!-- ══════════════════════════════════════════ -->
                <Border Grid.Row="2" Grid.Column="2"
                        Padding="32,30" BackgroundColor="White"
                        Stroke="#CBDCEB" StrokeThickness="1"
                        VerticalOptions="Start">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="40" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,6" Radius="24" Opacity="0.07" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">

                        <!-- Heading -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Label Text="🏆" FontSize="16" VerticalOptions="Center" />
                            <Label Text="LEADERBOARD"
                                   FontAttributes="Bold" FontSize="11"
                                   TextColor="#0F2D4A" CharacterSpacing="2.6"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" BackgroundColor="#CBDCEB" Margin="0,0,0,4" />

                        <!-- Top entry highlight -->
                        <Border Padding="20,16" Stroke="#E8C547" StrokeThickness="1.5">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFF8DC" Offset="0" />
                                    <GradientStop Color="#FAF0CA" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label Grid.Column="0" Text="🥇" FontSize="22"
                                       VerticalOptions="Center" Margin="0,0,10,0" />
                                <Label Grid.Column="1" Text="{Binding TopPlayerName}"
                                       FontAttributes="Bold" FontSize="20"
                                       TextColor="#0F2D4A" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding TopPlayerScore}"
                                       FontSize="13" TextColor="#6B8CAE"
                                       VerticalOptions="Center" FontAttributes="Bold" />
                            </Grid>
                        </Border>

                        <!-- Secondary entries -->
                        <Border Padding="18,14" BackgroundColor="#F2F6FB"
                                Stroke="#CBDCEB" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label Grid.Column="0" Text="🥈" FontSize="18"
                                       VerticalOptions="Center" Margin="0,0,10,0" />
                                <Label Grid.Column="1" Text="—"
                                       FontSize="16" TextColor="#6B8CAE"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Padding="18,14" BackgroundColor="#F2F6FB"
                                Stroke="#CBDCEB" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label Grid.Column="0" Text="🥉" FontSize="18"
                                       VerticalOptions="Center" Margin="0,0,10,0" />
                                <Label Grid.Column="1" Text="—"
                                       FontSize="16" TextColor="#6B8CAE"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" BackgroundColor="#CBDCEB" />

                        <!-- Score controls -->
                        <Border BackgroundColor="#0F2D4A" Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="28" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,6" Radius="18" Opacity="0.22" />
                            </Border.Shadow>
                            <Button Text="▲  Increase Score"
                                    Command="{Binding AddValueCommand}"
                                    BackgroundColor="Transparent" TextColor="White"
                                    BorderWidth="0" HeightRequest="54"
                                    FontAttributes="Bold" FontSize="14"
                                    CharacterSpacing="0.8" />
                        </Border>

                        <Border BackgroundColor="Transparent"
                                Stroke="#CBDCEB" StrokeThickness="1.5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="28" />
                            </Border.StrokeShape>
                            <Button Text="▼  Decrease Score"
                                    Command="{Binding SubtractValueCommand}"
                                    BackgroundColor="Transparent" TextColor="#0F2D4A"
                                    BorderWidth="0" HeightRequest="54"
                                    FontAttributes="Bold" FontSize="14"
                                    CharacterSpacing="0.8" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
