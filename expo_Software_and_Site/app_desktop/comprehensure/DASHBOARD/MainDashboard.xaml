<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="comprehensure.DASHBOARD.MainDashboard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#f4f9fd"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <Grid Padding="30" ColumnSpacing="30" HorizontalOptions="Center">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="450" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout Grid.Column="0" 
                                 BackgroundColor="#fdfdfd" 
                                 Padding="20" 
                                 Spacing="25"
                                 VerticalOptions="Start">
                <Label Text="PROFILE" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" TextColor="#1B3A57" />
                
                <Border HeightRequest="120" WidthRequest="120" HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="60" />
                    </Border.StrokeShape>
                    <ImageButton Source="user.png" Aspect="AspectFill" Clicked="ProfileButton_Clicked" />
                </Border>
                <Label Text="User_Name" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#1B3A57" />
                <Button Text="Settings" BorderColor="#80c2ed" BorderWidth="1" CornerRadius="15" TextColor="#80c2ed" BackgroundColor="Transparent"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" Spacing="30" VerticalOptions="Start">
                <Label Text="DASHBOARD" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#1B3A57" />
                <Border HeightRequest="250" Stroke="#80c2ed" StrokeThickness="2" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Label Text="{Binding DisplayPercentage}" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#80c2ed" />
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                    <Button Grid.Column="0" Text="MODULES" BackgroundColor="#eaed80" CornerRadius="20" HeightRequest="50" TextColor="#1B3A57" Clicked="ModulesButton_Clicked" />
                    <Button Grid.Column="1" Text="ABOUT US" BackgroundColor="#BDE0FE" CornerRadius="20" HeightRequest="50" TextColor="#1B3A57" Clicked="AboutUsButton_Clicked" />
                </Grid>

                <Border Padding="25" BackgroundColor="#80c2ed">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Label Text="quote from the group (placeholder)" FontAttributes="Italic" HorizontalTextAlignment="Center" TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" 
                                 BackgroundColor="#fdfdfd" 
                                 Padding="20" 
                                 Spacing="20"
                                 VerticalOptions="Start">
                <Label Text="LEADERBOARD" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" TextColor="#1B3A57" />
                <Border Padding="10" BackgroundColor="#f0f8ff" Stroke="#BDE0FE" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Label Text="1. abber" TextColor="#1B3A57" />
                </Border>
            </VerticalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>