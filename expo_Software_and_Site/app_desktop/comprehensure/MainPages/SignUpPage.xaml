<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="comprehensure.SignUpPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#f4f9fd">

    <Grid RowDefinitions="Auto, *">
        <Label Padding="25,20" FontAttributes="Bold" FontSize="20" Text="ComprehenSure" TextColor="#1B3A57" />


        <ScrollView Grid.Row="1" VerticalOptions="Center">
            <VerticalStackLayout Padding="30" Spacing="30" MaximumWidthRequest="450">
                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                    <Label Text="Create Account" FontSize="32" FontAttributes="Bold" TextColor="#1B3A57" HorizontalOptions="Center" />
                    <Label Text="Join our community of readers" TextColor="#507D9B" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Border BackgroundColor="White" Padding="30" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="25" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="20">
                        <Entry x:Name="EmailEntry" Placeholder="Email Address" TextColor="#1B3A57" BackgroundColor="#f9fdff" Text="{Binding Email}" HeightRequest="50" />

                        <Entry x:Name="PasswordNonConf" Placeholder="Password" IsPassword="True" TextColor="#1B3A57" BackgroundColor="#f9fdff" Text="{Binding Password}" HeightRequest="50" />

                        <Button x:Name="SignUpButton" Text="SIGN UP" Command="{Binding SignUpCommand}"
                                BackgroundColor="#80c2ed" TextColor="White" CornerRadius="25" HeightRequest="55" FontAttributes="Bold" Margin="0,10,0,0" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>