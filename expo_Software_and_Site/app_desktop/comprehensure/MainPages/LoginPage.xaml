<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="comprehensure.LoginPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#F2F6FB"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Background decorative blobs -->
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" InputTransparent="True">
            <Ellipse Fill="White"   WidthRequest="580" HeightRequest="440"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="-140,-110,0,0" Opacity="0.75" />
            <Ellipse Fill="#D6EAFF" WidthRequest="460" HeightRequest="380"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-110,-60" Opacity="0.45" />
        </Grid>

        <ScrollView HorizontalOptions="Center" VerticalOptions="Center">
            <VerticalStackLayout Spacing="32" WidthRequest="440" Padding="20">

                <Label Text="ComprehenSure"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#0F2D4A" CharacterSpacing="2.5"
                           HorizontalOptions="Center"
                           Margin="0,6,0,0" />

                <!-- ── Heading ── -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="Welcome Back"
                           FontSize="34" FontAttributes="Bold"
                           TextColor="#0F2D4A"
                           HorizontalOptions="Center" />
                    <Label Text="Sign in to continue your journey"
                           TextColor="#6B8CAE" FontSize="15"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- ── Form card ── -->
                <Border BackgroundColor="White"
                        Padding="36,32"
                        Stroke="#CBDCEB" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="36" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,10" Radius="32" Opacity="0.07" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">

                        <!-- Email field -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="EMAIL ADDRESS"
                                   FontSize="10" FontAttributes="Bold"
                                   TextColor="#6B8CAE" CharacterSpacing="1.8" />
                            <Border BackgroundColor="#F2F6FB"
                                    Stroke="#CBDCEB" StrokeThickness="1"
                                    Padding="18,0" HeightRequest="52">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Entry x:Name="Email"
                                       Placeholder="you@example.com"
                                       PlaceholderColor="#A8C4D8"
                                       TextColor="#0F2D4A"
                                       BackgroundColor="Transparent"
                                       Text="{Binding Email}"
                                       FontSize="15"
                                       VerticalOptions="Center"
                                       Keyboard="Email" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password field -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="PASSWORD"
                                   FontSize="10" FontAttributes="Bold"
                                   TextColor="#6B8CAE" CharacterSpacing="1.8" />
                            <Border BackgroundColor="#F2F6FB"
                                    Stroke="#CBDCEB" StrokeThickness="1"
                                    Padding="18,0" HeightRequest="52">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Entry x:Name="Password"
                                       Placeholder="••••••••"
                                       PlaceholderColor="#A8C4D8"
                                       IsPassword="True"
                                       TextColor="#0F2D4A"
                                       BackgroundColor="Transparent"
                                       Text="{Binding Password}"
                                       FontSize="15"
                                       VerticalOptions="Center" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" BackgroundColor="#EBF4FF" Margin="0,8" />

                        <!-- Login button -->
                        <Border BackgroundColor="#0F2D4A"
                                Stroke="Transparent" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="26" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#0F2D4A" Offset="0,8" Radius="22" Opacity="0.24" />
                            </Border.Shadow>
                            <Button x:Name="Login_Button"
                                    Text="LOGIN"
                                    Command="{Binding LoginCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="White"
                                    BorderWidth="0"
                                    HeightRequest="54"
                                    FontAttributes="Bold" FontSize="15"
                                    CharacterSpacing="2.0" />
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Sign up link ── -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Label Text="Don't have an account?"
                           TextColor="#6B8CAE" FontSize="14" />
                    <Label Text="Sign Up"
                           TextColor="#0F2D4A" FontSize="14"
                           FontAttributes="Bold"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToSignUpCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
