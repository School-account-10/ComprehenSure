<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="comprehensure.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#f4f9fd"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">
        <Label Padding="25,20" FontAttributes="Bold" FontSize="20" Text="ComprehenSure" TextColor="#1B3A57" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="40" Spacing="30" VerticalOptions="Center">

                <Frame HeightRequest="220" 
       WidthRequest="220" 
       HorizontalOptions="Center" 
       Padding="0" 
       IsClippedToBounds="True"
       CornerRadius="110"
       BorderColor="Transparent"
       BackgroundColor="#f4f9fd">
                    <Image Aspect="AspectFill"   
           Source="appcs.png" 
           HorizontalOptions="Center"
           VerticalOptions="Center" />
                </Frame>

                <VerticalStackLayout Spacing="5">
                    <Label FontAttributes="Bold" FontSize="36" HorizontalOptions="Center" Text="ComprehenSure" TextColor="#1B3A57" />
                    <Label Text="Master reading comprehension with ease." HorizontalOptions="Center" TextColor="#507D9B" FontSize="16" />
                </VerticalStackLayout>

                <VerticalStackLayout MaximumWidthRequest="350" Spacing="15" HorizontalOptions="Center" WidthRequest="350">
                    <Button BackgroundColor="#80c2ed" Clicked="Button_login_Clicked" CornerRadius="25" HeightRequest="55" Text="Login" TextColor="White" FontAttributes="Bold" />

                    <Button BackgroundColor="Transparent" BorderColor="#80c2ed" BorderWidth="2" Clicked="Button_sign_up_Clicked" CornerRadius="25" HeightRequest="55" Text="Sign Up" TextColor="#80c2ed" FontAttributes="Bold" />
                </VerticalStackLayout>

                <Border Padding="20" BackgroundColor="#fffef0" HorizontalOptions="Center" MaximumWidthRequest="400" Stroke="#eaed80" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Label FontSize="13" HorizontalTextAlignment="Center" Text="placeholder." TextColor="#507D9B" FontAttributes="Italic" />
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>