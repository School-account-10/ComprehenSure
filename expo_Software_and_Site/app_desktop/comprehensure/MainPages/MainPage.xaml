<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="comprehensure.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#F2F6FB"
             Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Background decorative blobs -->
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" InputTransparent="True">
            <Ellipse Fill="White"   WidthRequest="580" HeightRequest="440"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="-140,-110,0,0" Opacity="0.75" />
            <Ellipse Fill="#D6EAFF" WidthRequest="460" HeightRequest="380"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-110,-60" Opacity="0.45" />
        </Grid>

        <ScrollView HorizontalOptions="Center" VerticalOptions="Center">
            <VerticalStackLayout Spacing="32" WidthRequest="400" Padding="20">

                <!-- ── Logo ── -->
                <!-- Key fix: BackgroundColor="Transparent" + no Frame border -->
                <Border HeightRequest="180" WidthRequest="180"
                        BackgroundColor="Transparent"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="90" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#0F2D4A" Offset="0,8" Radius="28" Opacity="0.12" />
                    </Border.Shadow>
                    <Image Source="appcs.png"
                           Aspect="AspectFill"
                           HeightRequest="180"
                           WidthRequest="180">
                        <Image.Clip>
                            <EllipseGeometry Center="90,90" RadiusX="90" RadiusY="90" />
                        </Image.Clip>
                    </Image>
                </Border>

                <!-- ── App name + tagline ── -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="ComprehenSure"
                           FontSize="34" FontAttributes="Bold"
                           TextColor="#0F2D4A"
                           HorizontalOptions="Center" />
                    <Label Text="Master reading comprehension with ease."
                           FontSize="15" TextColor="#6B8CAE"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- ── CTA buttons ── -->
                <VerticalStackLayout Spacing="14" HorizontalOptions="Fill">

                    <!-- Login — primary -->
                    <Border BackgroundColor="#0F2D4A"
                            Stroke="Transparent" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="28" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,8" Radius="22" Opacity="0.24" />
                        </Border.Shadow>
                        <Button Text="LOGIN"
                                Clicked="Button_login_Clicked"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                BorderWidth="0"
                                HeightRequest="56"
                                FontAttributes="Bold" FontSize="15"
                                CharacterSpacing="2.0" />
                    </Border>

                    <!-- Sign Up — outlined -->
                    <Border BackgroundColor="White"
                            Stroke="#CBDCEB" StrokeThickness="1.5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="28" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#0F2D4A" Offset="0,4" Radius="14" Opacity="0.07" />
                        </Border.Shadow>
                        <Button Text="SIGN UP"
                                Clicked="Button_sign_up_Clicked"
                                BackgroundColor="Transparent"
                                TextColor="#0F2D4A"
                                BorderWidth="0"
                                HeightRequest="56"
                                FontAttributes="Bold" FontSize="15"
                                CharacterSpacing="2.0" />
                    </Border>
                </VerticalStackLayout>

                <!-- ── Quote banner ── -->
                <Border Padding="24,18"
                        Stroke="#E8C547" StrokeThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFF8DC" Offset="0" />
                            <GradientStop Color="#FAF0CA" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="12">
                        <Label Grid.Column="0"
                               Text="&#x201C;"
                               FontSize="48" TextColor="#2E6BA8"
                               Opacity="0.3"
                               VerticalOptions="Start"
                               Margin="0,-6,0,0" />
                        <Label Grid.Column="1"
                               Text="Important truths can be found through curiosity and effort."
                               FontAttributes="Italic" FontSize="13"
                               TextColor="#3a2e00"
                               LineBreakMode="WordWrap"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
